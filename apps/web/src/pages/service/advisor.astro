---
import Layout from "../../layouts/Layout.astro";
import HeaderH2 from "../../components/ui/HeaderH2.astro";
import PDef from "../../components/ui/PDef.astro";
import CardDef from "../../components/ui/CardDef.astro";
import Fukidashi from "../../components/ui/Fukidashi.astro";
import BtnLink from "../../components/ui/BtnLink.astro";
import PageKeyVisual from "../../components/sections/PageKeyVisual.astro";
import { advisorConcerns, serviceFeatures } from "../../data/advisor";
---

<Layout title="専属顧問プラン | 集客のチカラ" breadcrumb="専属顧問プラン">
  <!-- キービジュアル -->
  <PageKeyVisual showBackgroundImage={true} backgroundImage="/images/bg-service-advisor.png" waveFill="#f5f5f5">
    <div class="relative flex flex-col items-center w-full max-w-[380px] h-[280px] mx-auto pt-6 pb-[350px] text-center z-30 md:ml-auto md:mr-[calc(50%-380px)] md:justify-center md:pt-0 md:pb-0">
      <h1 id="pro-kv-heading" class="font-semibold text-(--white) text-4xl md:text-5xl pb-4 tracking-widest">専属顧問プラン</h1>
      <p class="font-semibold leading-8 pb-5 text-(--white) md:text-lg tracking-wide">
        WEB 広告運用のプロフェッショナルによる<br />「専属顧問」という、新しい正解
      </p>
      <div class="w-full bg-(--white) text-lg text-(--service-advisor) leading-7 px-4 py-3 hidden md:block">
        <p class="font-semibold">税務は税理士へ、法務は弁護士へ。<br />WEB 広告運用は、誰に相談しますか？</p>
      </div>
    </div>
    <div class="absolute tracking-wide bottom-[65px] right-[16px] w-[240px] bg-(--white) leading-7 px-4 py-4 text-center text-(--service-advisor) rounded-lg md:hidden">
      <p class="font-semibold">税務は税理士へ<br />法務は弁護士へ<br />WEB広告運用は、<br />誰に相談しますか？</p>
    </div>
    <img
      src="/images/keyvisual-service-exclusive_badge.png"
      alt="WEB広告手数料ゼロへ"
      class="pointer-events-none absolute top-[45px] left-0 z-40 w-[100px] object-contain select-none md:w-[110px]"
      width="130"
      height="130"
      aria-hidden="true"
      draggable="false"
    />
    <img
      src="/images/keyvisual-service-exclusive_advisor.png"
      alt="専属顧問のイメージ"
      class="absolute bottom-[-130px] left-[12%] -translate-x-1/2 pointer-events-none mx-auto md:left-[120px] md:bottom-[-230px] w-[200px] md:w-[300px] md:-translate-x-0 object-contain z-20"
      width="280"
      height="220"
    />
  </PageKeyVisual>

  <!-- 第1セクション -->
  <section class="bg-(--base-bg-lgray) px-4 pb-6 pt-8 md:pb-10 md:pt-10" aria-labelledby="advisor-sec1-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="advisor-sec1-heading" class="mx-auto">
        貴社の<span class="text-(--main-text)">WEB広告運用</span>は<br class="md:hidden" />最善ですか？
      </HeaderH2>

      <PDef class="mx-auto max-w-[900px] text-center">
        WEB広告運用は専門知識に加え、日々の運用・改善にも多くの時間と手間がかかります。<br class="hidden md:block" />
        本来注力すべき業務に、十分なリソースを割けていない企業様も少なくありません。
      </PDef>

      <div class="mx-auto mt-4 flex max-w-[900px] flex-col items-center gap-2 md:flex-row md:items-stretch md:justify-center md:gap-4">
        <div class="relative order-2 z-0 -mb-14 flex w-full max-w-[280px] h-[150px] pr-[100px] shrink-0 justify-center md:order-none md:mb-0 md:w-[120px] md:max-w-none md:h-auto md:pr-0">
          <img
            src="/images/pic-man_worry.png"
            alt="悩んでいるビジネスパーソン"
            class="h-[200px] w-auto object-contain object-bottom md:absolute md:top-8 md:left-1/2 md:h-[280px] md:-translate-x-1/2"
            width="200"
            height="280"
            loading="lazy"
          />
        </div>

        <ul class="relative z-10 order-1 flex w-full max-w-[280px] flex-col gap-1 md:order-none md:max-w-[230px]">
          {
            advisorConcerns.map(({ lines }) => (
              <li>
                <Fukidashi tail="bottom-left" size="compact">
                  {lines[0]}
                  <br />
                  {lines[1]}
                </Fukidashi>
              </li>
            ))
          }
        </ul>

        <div class="hidden shrink-0 items-center justify-center md:flex md:w-16">
          <img src="/svg/arrow-right.svg" alt="" class="size-16" width="63" height="41" aria-hidden="true" />
        </div>

        <CardDef class="relative z-20 order-3 w-full md:max-w-[387px] overflow-hidden border-2 border-(--main-bg) p-0 md:order-none">
          <div class="bg-(--main-bg) px-4 py-1 text-center">
            <h3 class="text-base leading-6 font-semibold text-(--white)">"専属顧問プラン"におまかせください！</h3>
          </div>

          <div class="relative p-4 pr-[90px] md:pr-28">
            <p class="text-(length:--font-size-default) leading-6 text-(--base-text) md:pb-0 md:leading-7">
              税務に「<span class="font-bold text-(--main-text)">税理士</span>」、<br />
              法務に「<span class="font-bold text-(--main-text)">弁護士</span>」のように、<br />
              広告運用に「<span class="font-bold text-(--main-text)">専属顧問</span>」を。
            </p>
            <p class="text-right text-2xl font-bold text-(--base-text)">
              月額
              <span class="font-famly-din text-[56px] text-(--accent-strong)">５</span>万円で
            </p>
            <p class="text-right text-xs md:text-sm leading-6 text-(--base-text)">広告運用のプロが、貴社に伴走します。</p>
            <img
              src="/images/pic-service-exclusive_advisor.png"
              alt="アドバイザーの写真"
              class="pointer-events-none absolute right-[-20px] md:right-0 bottom-0 h-[200px] w-[120px] object-cover object-top"
              width="129"
              height="287"
              aria-hidden="true"
            />
          </div>
        </CardDef>
      </div>
    </div>
  </section>

  <!-- 第2セクション -->
  <section class="relative px-4 pb-10 pt-8 md:pb-16 md:pt-10" aria-labelledby="advisor-sec2-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="advisor-sec2-heading" class="mx-auto">
        サービス概要
        <Fragment slot="summary"> 複数アカウントの運用やスポット診断など、貴社に最適なプランをご提案します </Fragment>
      </HeaderH2>

      <div class="mx-auto grid max-w-[900px] grid-cols-2 gap-2 md:grid-cols-4 md:gap-5">
        {
          serviceFeatures.map(({ image, imageAlt, title, subtitle }) => (
            <CardDef class="flex flex-col items-center gap-2.5 py-6">
              <img src={image} alt={imageAlt} class="size-[100px] object-contain" width="100" height="100" loading="lazy" />
              <p class="text-center font-bold whitespace-pre-line text-(--base-text)">{title}</p>
              <p class="text-center text-base leading-6 text-(length:--font-size-small)">{subtitle}</p>
            </CardDef>
          ))
        }
      </div>

      <div class="relative mx-auto mt-6 flex flex-col max-w-[900px] items-start gap-3 bg-(--base-bg-lgray) px-6 pt-4 md:flex-row">
        <PDef class="flex-1 pb-0">
          広告代理店の運用や、自社運用にも、セカンドオピニオン（別の専門家による客観的な意見）の視点が必要です。広告運用のムダが無くなり、高効率化されることで、 広告投資効果が、最大化されます。
        </PDef>
        <img src="/images/illust-mushimegane.png" alt="虫眼鏡のイラスト" class="pointer-events-none size-[61px] shrink-0 object-contain ml-auto" width="61" height="61" aria-hidden="true" />
      </div>
      <div class="mt-6 flex justify-center">
        <BtnLink href="/pricing#pricing-advisor" label="サービス・料金の詳細はこちら" />
      </div>
    </div>
  </section>
</Layout>
