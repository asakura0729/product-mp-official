---
import Layout from '../../layouts/Layout.astro';
import SectionPlans from '../../components/sections/SectionPlans.astro';
import HeaderH2 from '../../components/ui/HeaderH2.astro';
import PDef from '../../components/ui/PDef.astro';
import CardDef from '../../components/ui/CardDef.astro';
import Fukidashi from '../../components/ui/Fukidashi.astro';
import BtnLink from '../../components/ui/BtnLink.astro';
import { advisorConcerns, serviceFeatures } from '../../data/advisor';
---

<Layout title="専属顧問プラン | 集客のチカラ" breadcrumb="専属顧問プラン">
	<!-- キービジュアル -->
	<section class="advisor-kv relative w-full overflow-hidden" aria-labelledby="advisor-kv-heading">
		<div class="relative min-h-[320px] w-full bg-(--main-bg) md:min-h-[350px]">
			<img
				src="/images/bg-office.jpg"
				alt=""
				class="pointer-events-none absolute inset-0 size-full object-cover opacity-25"
				aria-hidden="true"
			/>

			<img
				src="/images/keyvisual-home-zero.png"
				alt="代理店 手数料ゼロ！"
				class="pointer-events-none absolute top-6 left-4 z-10 h-[90px] w-auto object-contain md:top-7 md:left-[190px] md:h-[118px]"
				width="119"
				height="118"
			/>

			<img
				src="/images/pic-service-exclusive_advisor.png"
				alt=""
				class="pointer-events-none absolute right-0 bottom-0 hidden h-[min(467px,90%)] w-auto max-w-[45%] object-contain object-bottom md:block"
				width="255"
				height="467"
				aria-hidden="true"
			/>

			<div class="relative z-10 mx-auto flex w-full max-w-[395px] flex-col items-center px-4 pt-10 pb-16 text-center md:pt-12 md:pb-20">
				<h1
					id="advisor-kv-heading"
					class="text-[32px] font-semibold leading-[50px] tracking-[2.88px] text-(--white) md:text-[48px]"
				>
					専属顧問プラン
				</h1>
				<p class="mt-2 text-lg font-semibold leading-[30px] text-(--white)">
					WEB 広告運用のプロフェッショナルによる
					<br />
					「専属顧問」という、新しい正解
				</p>
				<div class="mt-3 w-full bg-(--white) px-4 py-2">
					<p class="text-base leading-[27px] font-bold text-(--service-advisor)">
						税務は税理士へ、法務は弁護士へ。
						<br />
						WEB 広告運用は、誰に相談しますか？
					</p>
				</div>
			</div>

			<img
				src="/images/pic-service-exclusive_advisor.png"
				alt=""
				class="pointer-events-none absolute right-0 bottom-0 h-[220px] w-auto object-contain object-bottom md:hidden"
				width="180"
				height="220"
				aria-hidden="true"
			/>
		</div>
	</section>

	<!-- 第1セクション -->
	<section
		class="bg-(--base-bg-lgray) px-4 pb-6 pt-8 md:pb-10 md:pt-10"
		aria-labelledby="advisor-sec1-heading"
	>
		<div class="mx-auto w-full max-w-(--container)">
			<HeaderH2 id="advisor-sec1-heading" class="mx-auto">
				貴社の<span class="text-(--main-text)">WEB 広告運用</span>は最善ですか？
			</HeaderH2>

			<PDef class="mx-auto max-w-[900px] text-center">
				WEB広告運用は専門知識に加え、日々の運用・改善にも多くの時間と手間がかかります。<br class="hidden md:block" />
				本来注力すべき業務に、十分なリソースを割けていない企業様も少なくありません。
			</PDef>

			<div class="mx-auto mt-4 flex max-w-[900px] flex-col items-center gap-4 md:flex-row md:items-stretch md:justify-center md:gap-4">
				<div class="relative flex w-full max-w-[280px] shrink-0 flex-col items-center md:w-[120px] md:max-w-none">
					<img
						src="/images/pic-man_worry.png"
						alt="悩んでいるビジネスパーソン"
						class="h-[200px] w-auto object-contain object-bottom md:absolute md:top-8 md:left-1/2 md:h-[280px] md:-translate-x-1/2"
						width="200"
						height="280"
						loading="lazy"
					/>
				</div>

				<ul class="flex w-full max-w-[280px] flex-col gap-1 md:max-w-[230px]">
					{
						advisorConcerns.map(({ lines }) => (
							<li>
								<Fukidashi tail="bottom-left" size="compact">
									{lines[0]}
									<br />
									{lines[1]}
								</Fukidashi>
							</li>
						))
					}
				</ul>

				<div class="flex shrink-0 items-center justify-center py-2 md:w-16 md:py-0">
					<img
						src="/svg/arrow-right.svg"
						alt=""
						class="hidden size-16 md:block"
						width="63"
						height="41"
						aria-hidden="true"
					/>
					<img
						src="/svg/arrow-down.svg"
						alt=""
						class="size-12 md:hidden"
						width="48"
						height="48"
						aria-hidden="true"
					/>
				</div>

				<CardDef class="relative w-full max-w-[387px] overflow-hidden border-2 border-(--main-bg) p-0">
					<div class="bg-(--main-bg) px-4 py-1 text-center">
						<h3 class="text-base leading-8 font-bold text-(--white)">
							"専属顧問プラン" におまかせください！
						</h3>
					</div>

					<div class="relative p-4 pr-28">
						<p class="text-(length:--font-size-default) leading-8 text-(--base-text)">
							税務に「<span class="font-bold text-(--main-text)">税理士</span>」、
							<br />
							法務に「<span class="font-bold text-(--main-text)">弁護士</span>」のように、
							<br />
							広告運用に「<span class="font-bold text-(--main-text)">専属顧問</span>」を。
						</p>

						<p class="mt-2 text-right text-2xl leading-[34px] font-bold text-(--base-text)">
							月額
							<span class="font-famly-din text-[56px] leading-[34px] text-(--accent-strong)"
								>５</span
							>万円で
						</p>
						<p class="text-right text-sm leading-[27px] text-(--base-text)">
							広告運用のプロが、貴社に伴走します。
						</p>

						<img
							src="/images/pic-service-exclusive_advisor.png"
							alt=""
							class="pointer-events-none absolute right-0 bottom-0 h-[200px] w-[120px] object-cover object-top"
							width="129"
							height="287"
							aria-hidden="true"
						/>
					</div>
				</CardDef>
			</div>
		</div>
	</section>

	<!-- 第2セクション -->
	<section class="relative px-4 pb-10 pt-8 md:pb-16 md:pt-10" aria-labelledby="advisor-sec2-heading">
		<div class="mx-auto w-full max-w-(--container)">
			<HeaderH2 id="advisor-sec2-heading" class="mx-auto">
				サービス概要
				<Fragment slot="summary">
					複数アカウントの運用やスポット診断など、貴社に最適なプランをご提案します
				</Fragment>
			</HeaderH2>

			<div class="mx-auto grid max-w-[900px] grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4 md:gap-5">
				{
					serviceFeatures.map(({ image, imageAlt, title, subtitle }) => (
						<CardDef class="flex flex-col items-center gap-2.5 py-6">
							<img
								src={image}
								alt={imageAlt}
								class="size-[100px] object-contain"
								width="100"
								height="100"
								loading="lazy"
							/>
							<p class="text-center font-bold whitespace-pre-line text-(--base-text)">
								{title}
							</p>
							<p class="text-center text-base leading-6 text-(length:--font-size-small)">{subtitle}</p>
						</CardDef>
					))
				}
			</div>

			<div class="relative mx-auto mt-6 flex max-w-[900px] items-start gap-3 bg-(--base-bg-lgray) px-6 py-4">
				<PDef class="flex-1 pb-0">
					広告代理店の運用や、自社運用にも、セカンドオピニオン（別の専門家による客観的な意見）の視点が必要です。広告運用のムダが無くなり、高効率化されることで、
					広告投資効果が、最大化されます。
				</PDef>
				<img
					src="/images/illust-mushimegane.png"
					alt=""
					class="pointer-events-none hidden size-[61px] shrink-0 object-contain md:block"
					width="61"
					height="61"
					aria-hidden="true"
				/>
			</div>

			<div class="mt-6 flex justify-center">
				<BtnLink href="#" label="サービス・料金の詳細はこちら" />
			</div>
		</div>
	</section>

</Layout>
