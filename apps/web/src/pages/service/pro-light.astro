---
import Layout from "../../layouts/Layout.astro";
import CtaSection from "../../components/sections/CtaSection.astro";
import HeaderH2 from "../../components/ui/HeaderH2.astro";
import HeaderH3 from "../../components/ui/HeaderH3.astro";
import PDef from "../../components/ui/PDef.astro";
import CardPlan from "../../components/ui/CardPlan.astro";
import CardDl from "../../components/ui/CardDl.astro";
import CardOl from "../../components/ui/CardOl.astro";
import CardFaq from "../../components/ui/CardFaq.astro";
import BtnLink from "../../components/ui/BtnLink.astro";
import SecPortfolio from "../../components/ui/SecPortfolio.astro";
import { proPlans, apoSteps, onboardingSteps, contractTable, proFaqs, traditionalComparison, apoComparison } from "../../data/pro-light";
---

<Layout title="プロ運用プラン | 集客のチカラ" breadcrumb="プロ運用プラン">
  <!-- キービジュアル -->
  <section class="relative w-full overflow-hidden bg-(--main-bg)" aria-labelledby="pro-kv-heading">
    <div class="relative min-h-[320px] w-full md:min-h-[350px]">
      <img src="/images/bg-office.jpg" alt="" class="pointer-events-none absolute inset-0 size-full object-cover opacity-25" aria-hidden="true" />
      <img
        src="/images/keyvisual-home-zero.png"
        alt="代理店 手数料ゼロ！"
        class="pointer-events-none absolute top-6 left-4 z-10 h-[90px] w-auto object-contain md:top-12 md:left-[190px] md:h-[101px]"
        width="101"
        height="101"
      />
      <img
        src="/images/pic-human-service-pro_light.png"
        alt=""
        class="pointer-events-none absolute bottom-0 left-0 hidden h-[min(370px,85%)] w-auto object-contain object-bottom md:block"
        width="445"
        height="370"
        aria-hidden="true"
      />

      <div class="relative z-10 mx-auto flex w-full max-w-[363px] flex-col items-center px-4 py-10 text-center md:ml-auto md:mr-[calc(50%-450px)] md:items-start md:py-12 md:text-left">
        <h1 id="pro-kv-heading" class="text-[32px] font-semibold leading-[50px] tracking-[2.88px] text-(--white) md:text-[48px]">プロ運用プラン</h1>
        <div class="mt-3 w-full bg-(--white) px-4 py-2">
          <p class="text-2xl font-semibold leading-8 text-(--main-bg)">圧倒的なコスト削減</p>
        </div>
        <p class="mt-3 text-base leading-8 font-semibold text-(--white) md:text-lg">
          もう、<span class="text-2xl">手数料に悩まない</span>。
          <br />
          プロの WEB 広告運用を驚きの低価格・定額性で！
        </p>
      </div>

      <img src="/images/pic-human-service-pro_light.png" alt="プロ運用チームのイメージ" class="pointer-events-none mx-auto mt-4 h-[220px] w-auto object-contain md:hidden" width="280" height="220" />
    </div>
  </section>

  <!-- 第1セクション -->
  <section class="px-4 pb-10 pt-8 md:pb-12" aria-labelledby="pro-sec1-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="pro-sec1-heading" class="mx-auto">
        <Fragment slot="lead">WEB 広告の運用 2 つの選択肢には</Fragment>
        広告手数料は&nbsp;<span class="text-(--main-text)">全プラン「ゼロ」</span>
      </HeaderH2>

      <div class="md:hidden">
        <div class="flex gap-2 overflow-x-auto pb-2">
          {
            proPlans.map((plan) => (
              <div class="shrink-0 border border-(--border) bg-(--white) px-3 py-2 text-xs leading-5 text-center">
                プロ運用
                <br />
                {plan.tabLabel}
              </div>
            ))
          }
        </div>
      </div>

      <div class="mx-auto pb-6 grid max-w-[900px] grid-cols-1 gap-4 md:grid-cols-3">
        {
          proPlans.map((plan) => (
            <CardPlan
              planLead={plan.planLead}
              planTitle={plan.planTitle}
              catchLine={plan.catchLine}
              price={plan.price}
              priceLabel={plan.priceLabel}
              description={plan.description}
              features={plan.features}
            />
          ))
        }
      </div>

      <div class="flex justify-center">
        <BtnLink href="/pricing" label="サービス・料金の詳細はこちら" />
      </div>
    </div>
  </section>

  <CtaSection variant="contact-only" />

  <!-- 第2セクション -->
  <section class="pt-8" aria-labelledby="pro-sec2-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="pro-sec2-heading" class="mx-auto">
        広告費に比例して膨らむ、その<br class="md:hidden" /><span class="text-(--main-text)">手数料をゼロに</span>
      </HeaderH2>
      <PDef class="mx-auto max-w-[826px] md:text-center px-4">
        中間マージンは、元々「<span class="text-(--main-text)">マスメディア時代のモデル</span>」。<br />
        広告費に比例して手数料が増えるコスト構造は、「世界の常識」とかけ離れた仕組みです。
      </PDef>
      <div class="mx-auto mt-8 flex flex-col items-center gap-6 md:flex-row md:gap-8">
        <img
          src="/images/pic-2employees_commission.png"
          alt="広告代理店の手数料に悩むビジネスパーソン"
          class="self-start w-[75%] md:max-w-[40%] lg:max-w-[450px] rounded-tr-2xl rounded-br-2xl object-cover md:rounded-t-2xl md:rounded-br-none md:self-auto"
          width="453"
          height="417"
          loading="lazy"
        />
        <img
          src="/images/graph-comparison_cost.png"
          alt="コストダウンの比較グラフ"
          class="mx-auto pb-6 w-[75%] md:max-w-[40%] lg:max-w-[420px] object-contain md:mx-0"
          width="373"
          height="297"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- 第3セクション -->
  <section class="bg-(--base-bg-lblue) px-4 py-8 md:py-12" aria-labelledby="pro-sec3-heading">
    <div class="mx-auto w-full max-w-(--container) relative">
      <img
        src="/images/fig-apo.png"
        alt="「APO」（AD Portfolio Optimizer）"
        class="pointer-events-none mx-auto pb-4 md:absolute top-[-56px] right-4 h-auto w-[100px] object-contain md:block"
        width="140"
        height="126"
        aria-hidden="true"
      />
      <HeaderH2 id="pro-sec3-heading" class="mx-auto">
        <Fragment slot="lead">横並びの広告に、終止符を</Fragment>
        <span class="text-(--main-text)">ポートフォリオ</span>で運用する時代へ
      </HeaderH2>
      <PDef class="md:text-center"> 「APO」（AD Portfolio Optimizer）は、貴社の目的・目標に合わせて<br class="hidden md:block" />媒体配分を専用設計する、新しい WEB 広告運用メソッドです。 </PDef>

      <div class="mt-6 flex snap-x snap-mandatory gap-1 overflow-x-auto pb-4 lg:flex-nowrap lg:items-center lg:justify-center lg:overflow-visible lg:pb-0">
        {
          apoSteps.map((item, index) => (
            <>
              <CardOl step={item.step} title={item.title} image={item.image} imageAlt={item.imageAlt} class="w-full max-w-[300px] shrink-0 snap-center lg:w-auto lg:flex-1">
                {item.body}
              </CardOl>
              {index < apoSteps.length - 1 && (
                <div class="shrink-0 items-center justify-center self-center lg:flex lg:w-[75px]">
                  <img src="/svg/arrow-right.svg" alt="" class="h-10 w-16 object-contain" width="63" height="41" aria-hidden="true" />
                </div>
              )}
            </>
          ))
        }
      </div>

      <HeaderH3 align="center" class="mt-8">
        貴社の目的・目標に合わせて、<span class="text-(--main-text)">媒体配分を専用設計</span>
      </HeaderH3>
      <SecPortfolio class="mx-auto mt-4" />
    </div>
  </section>

  <!-- 第4セクション -->
  <section aria-labelledby="pro-sec4-heading" class="px-4 pt-6 pb-8">
    <div class="relative mx-auto w-full max-w-(--container)">
      <img
        src="/images/pic-human-service-pro_light.png"
        alt="スタッフ写真"
        class="pointer-events-none absolute top-[60px] right-0 hidden w-[150px] z-10 object-contain md:block"
        width="183"
        height="151"
        aria-hidden="true"
      />

      <HeaderH2 id="pro-sec4-heading" class="mx-auto max-w-[900px]">
        <Fragment slot="lead">自動運用が生む " 横並び " を</Fragment>
        <span class="text-(--main-text)">プロの知見</span>が打ち破る
      </HeaderH2>
      <PDef class="pb-6">
        横並びの広告から抜け出し、市場の主導権を握る。<br class="hidden md:block" />
        プロの知見による専用設計が、圧倒的な集客の『差』を生み出します
      </PDef>

      <p class="mb-4 text-center text-sm font-bold text-(--main-text) md:hidden">サービス比較</p>

      <div class="mx-auto mb-6 flex max-w-[400px] overflow-hidden md:hidden">
        <div class="flex flex-1 items-center justify-center bg-(--base-bg-lgray) px-2 py-3 text-center text-xs leading-5 font-bold text-(--base-text)">
          従来型の<br />自動運用システム
        </div>
        <div class="flex w-10 shrink-0 items-center justify-center text-sm font-bold text-[#999999]">VS</div>
        <div class="flex flex-1 items-center justify-center bg-(--main-bg) px-2 py-3 text-center text-xs leading-5 font-bold text-(--white)">
          集客の<br />チカラ
        </div>
      </div>

      <div class="relative z-20 mx-auto pb-8 flex flex-col items-center gap-6 md:flex-row md:items-center md:justify-center md:gap-4">
        <div class="w-full overflow-hidden rounded-(--border-radius) bg-(--base-bg-lgray)">
          <div class="px-4 py-4 text-center">
            <p class="text-sm leading-6 text-(--base-text)">従来型の</p>
            <p class="text-xl font-bold leading-8 text-(--base-text)">自動運用システム</p>
          </div>
          <img src="/images/pic-automatic_operation.png" alt="自動運用システムのイメージ" class="w-full object-cover" width="401" height="200" loading="lazy" />
          <div class="flex flex-col gap-2.5 p-4">
            {
              traditionalComparison.map(({ num, title, body }) => (
                <div class="bg-(--white) p-4 min-h-[152px]">
                  <div class="mb-2 flex items-center gap-2.5">
                    <span class="flex size-[30px] shrink-0 items-center justify-center rounded-full bg-(--main-text) text-base text-(--white)">{num}</span>
                    <p class="text-base font-bold text-(--base-text)">{title}</p>
                  </div>
                  <p class="text-sm leading-[27px] text-(--base-text)">{body}</p>
                </div>
              ))
            }
          </div>
        </div>

        <p class="text-center text-[56px] leading-none font-bold text-[#999999] md:shrink-0">VS</p>

        <div class="w-full overflow-hidden rounded-(--border-radius) bg-(--base-bg-lblue)">
          <div class="bg-(--main-bg) px-4 py-4 text-center text-(--white)">
            <p class="text-2xl font-bold leading-8">集客のチカラ</p>
            <p class="text-base leading-6">APO（AD Portfolio Optimizer）</p>
          </div>
          <img src="/images/pic-apo.png" alt="プロ運用のイメージ" class="w-full object-cover" width="401" height="200" loading="lazy" />
          <div class="flex flex-col gap-2.5 p-4">
            {
              apoComparison.map(({ num, title, body }) => (
                <div class="bg-(--white) p-4 min-h-[152px]">
                  <div class="mb-2 flex items-center gap-2.5">
                    <span class="flex size-[30px] shrink-0 items-center justify-center rounded-full bg-(--main-text) text-base text-(--white)">{num}</span>
                    <p class="text-base font-bold text-(--base-text)">{title}</p>
                  </div>
                  <p class="text-sm leading-[27px] text-(--base-text)">{body}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <section>
      <header class="text-center pb-2">
        <HeaderH3 class="text-(--main-text)">プロ運用プラン</HeaderH3>
        <PDef>広告代理 手数料をゼロに！<br class="md:hidden" />WEB広告運用をプロが全面サポート</PDef>
      </header>

      <div class="bg-(--main-bg-sub) px-4 py-4">
        <div class="mx-auto grid max-w-[900px] grid-cols-1 gap-2 md:gap-4 md:grid-cols-3">
          {
            proPlans.map((plan) => (
              <CardDl title={plan.planTitle}>
                <p class="pb-4 text-center text-sm leading-6">{plan.catchLine}</p>
                <p class="text-center">
                  {
                    plan.priceLabel ? (
                      <span class="text-2xl leading-8 font-bold">{plan.priceLabel}</span>
                    ) : (
                      <>
                        <span class="pr-1 text-2xl leading-5 font-bold">月額</span>
                        <span class="font-family-din text-[48px] leading-5 font-bold text-(--accent-strong)">{plan.price}</span>
                        <span class="pl-1 text-2xl leading-5 font-bold">万円～</span>
                      </>
                    )
                  }
                </p>
              </CardDl>
            ))
          }
        </div>
      </div>
    </section>
    <CtaSection variant="contact-only" />
  </section>

  <!-- 第5セクション -->
  <section class="px-4" aria-labelledby="pro-sec5-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="pro-sec5-heading" class="mx-auto">
        <Fragment slot="lead">透明な契約体系で、 無駄のない</Fragment>
        「新スタンダード」 の広告運用を
      </HeaderH2>
      <section class="pb-6">
        <HeaderH3 align="left" class="mx-auto max-w-[900px]">ご契約条件</HeaderH3>
        <div class="mx-auto max-w-[900px] overflow-x-auto">
          <table class="min-w-[720px] w-full border-collapse text-sm leading-6">
            <thead>
              <tr>
                <th class="border border-(--border) bg-(--main-bg) px-4 py-2 text-left font-medium text-(--white)">項目</th>
                {contractTable.columns.map((col) => <th class="border border-(--border) bg-(--main-bg) px-4 py-2 text-center font-medium text-(--white)">{col}</th>)}
              </tr>
            </thead>
            <tbody class="text-(length:--font-size-small)">
              {
                contractTable.rows.map((row) => (
                  <tr>
                    <th class="border border-(--border) bg-(--base-bg-lblue) px-4 py-2 text-left font-medium text-(--base-text)">{row.label}</th>
                    {row.values.map((value) => (
                      <td class="border border-(--border) bg-(--white) px-4 py-2 text-center text-(--base-text)">{value}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>
      <section class="pb-6">
        <HeaderH3 align="left" class="mx-auto">導入までの３ステップ</HeaderH3>
        <div class="mx-auto flex snap-x snap-mandatory gap-2 overflow-x-auto pb-4 lg:flex-nowrap lg:items-center lg:justify-center lg:overflow-visible lg:pb-0">
          {
            onboardingSteps.map((item, index) => (
              <>
                <CardOl step={item.step} title={item.title} showImage={false} class="h-auto max-w-[280px] shrink-0 snap-center lg:w-auto lg:max-w-none lg:flex-1">
                  {item.body}
                </CardOl>
                {index < onboardingSteps.length - 1 && (
                  <div class="shrink-0 items-center justify-center self-center lg:flex lg:w-[75px]">
                    <img src="/svg/arrow-right.svg" alt="" class="h-10 w-16 object-contain" width="63" height="41" aria-hidden="true" />
                  </div>
                )}
              </>
            ))
          }
        </div>
      </section>
    </div>
  </section>

  <!-- 第6セクション -->
  <section class="bg-(--base-bg-lgray) px-4 py-8" aria-labelledby="pro-sec6-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="pro-sec6-heading" class="mx-auto">
        <Fragment slot="lead">集客のチカラ 広告運用に頂いた</Fragment>
        よくあるご質問（FAQ）
      </HeaderH2>
      <div class="mx-auto grid max-w-[900px] grid-cols-1 gap-4 md:grid-cols-3">
        {proFaqs.map(({ question, answer }) => <CardFaq question={question} answer={answer} />)}
      </div>
    </div>
  </section>

  <!-- 第7セクション（フッター前） -->
  <section class="bg-(--base-bg-lblue) px-4 py-8" aria-labelledby="pro-sec7-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="pro-sec7-heading" class="mx-auto text-(--main-text)"> 今の広告運用と手数料、本当に適正ですか？ </HeaderH2>
      <PDef class="mx-auto max-w-[900px] text-center"> まずは、貴社の「手数料コストの適正化診断」から 「手数料ゼロ化のシミュレーション」まで、無料で行います。 </PDef>
    </div>
  </section>
</Layout>
