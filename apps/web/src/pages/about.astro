---
import Layout from '../layouts/Layout.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import HeaderH2 from '../components/ui/HeaderH2.astro';
import HeaderH3 from '../components/ui/HeaderH3.astro';
import PDef from '../components/ui/PDef.astro';
import CardDef from '../components/ui/CardDef.astro';
import ServicePlanButton from '../components/ui/ServicePlanButton.astro';
import SecPortfolio from '../components/ui/SecPortfolio.astro';
import {
	choiceProblems,
	costSolutions,
	growthCycleSteps,
	marginQaAnswer,
} from '../data/about';
---

<Layout title="集客のチカラとは | 集客のチカラ" breadcrumb="集客のチカラとは">
	<!-- キービジュアル -->
	<section class="about-kv relative w-full bg-[#294C7A]" aria-labelledby="about-kv-heading">
		<div class="mx-auto flex w-full max-w-[600px] flex-col items-center gap-2 px-4 py-9 text-center md:gap-2 md:py-12">
			<p class="text-base font-semibold leading-8 text-(--main-bg-sub)">Growth Asset Advertising</p>
			<h1
				id="about-kv-heading"
				class="text-2xl font-semibold leading-[38px] text-(--white) md:text-(length:--font-size-h2) md:leading-(length:--line-height-h2)"
			>
				「成長投資型」の広告運用へ
			</h1>
			<p class="text-base font-medium leading-8 text-(--white)">
				従来の WEB 広告運用は、中間マージンや過剰な運用コストが、事業成長の " 足枷 "
				になっていました 私たちはこのコスト構造を一新し、広告を " コスト" から" 複利を生む成長投資 "
				へと変えます
			</p>
		</div>
	</section>

	<!-- 第1セクション -->
	<section class="px-4 pb-10 pt-4 md:pb-16" aria-labelledby="about-sec1-heading">
		<div class="relative mx-auto w-full max-w-(--container)">
			<img
				src="/images/illust-human_think.png"
				alt=""
				class="pointer-events-none absolute top-0 right-0 hidden h-[127px] w-[147px] object-cover md:block"
				width="147"
				height="127"
				aria-hidden="true"
			/>

			<HeaderH2 id="about-sec1-heading" class="mx-auto max-w-[900px]">
				<Fragment slot="lead">WEB 広告の運用 2 つの選択肢には</Fragment>
				<span class="text-(--main-text)">大きな課題</span>がありました
			</HeaderH2>

			<div class="mx-auto mt-4 flex max-w-[900px] flex-col gap-4 md:flex-row md:gap-4">
				{
					choiceProblems.map(({ image, imageAlt, title, body }) => (
						<CardDef class="flex flex-1 items-center gap-4 p-(--pd-middle)">
							<img
								src={image}
								alt={imageAlt}
								class="size-11 shrink-0 object-contain"
								width="45"
								height="45"
								loading="lazy"
							/>
							<div class="min-w-0 flex-1">
								<h3 class="text-base leading-[27px] font-bold text-(--base-text)">{title}</h3>
								<p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">{body}</p>
							</div>
						</CardDef>
					))
				}
			</div>
		</div>
	</section>

	<!-- 第2セクション -->
	<section
		class="relative bg-(--base-bg-lblue) px-4 pb-4 pt-10 md:pt-16"
		aria-labelledby="about-sec2-heading"
	>
		<div class="pointer-events-none absolute top-[-55px] left-1/2 -translate-x-1/2">
			<img
				src="/svg/arrow-down.svg"
				alt=""
				class="size-[88px] md:size-[110px]"
				width="110"
				height="110"
				aria-hidden="true"
			/>
		</div>

		<img
			src="/images/illust-human_OK.png"
			alt=""
			class="pointer-events-none absolute top-[-65px] right-4 hidden h-[158px] w-[158px] object-cover md:block"
			width="158"
			height="158"
			aria-hidden="true"
		/>

		<div class="mx-auto w-full max-w-(--container)">
			<HeaderH2 id="about-sec2-heading" class="mx-auto max-w-[900px]">
				<Fragment slot="lead">その課題を解決するため</Fragment>
				広告運用コストの<span class="text-(--main-text)">「常識」を変えます</span>！
			</HeaderH2>

			<div class="mx-auto mt-4 flex max-w-[900px] flex-col gap-4 md:flex-row md:gap-4">
				{
					costSolutions.map(({ image, imageAlt, title, titleHighlight, titleSuffix, body }) => (
						<CardDef class="flex flex-1 items-center gap-4 p-(--pd-middle)">
							<img
								src={image}
								alt={imageAlt}
								class="size-11 shrink-0 object-contain"
								width="45"
								height="45"
								loading="lazy"
							/>
							<div class="min-w-0 flex-1">
								<h3 class="text-base leading-[27px] font-bold text-(--base-text)">
									{title}
									<span class="text-(--main-text)">{titleHighlight}</span>
									{titleSuffix}
								</h3>
								<p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">{body}</p>
							</div>
						</CardDef>
					))
				}
			</div>
		</div>
	</section>

	<!-- 第3セクション -->
	<section class="relative px-4 pb-12 pt-8 md:pb-16 md:pt-10" aria-labelledby="about-sec3-heading">
		<div class="relative mx-auto w-full max-w-(--container)">
			<img
				src="/images/illust-two_buildings.png"
				alt=""
				class="pointer-events-none absolute top-0 left-0 hidden h-[133px] w-[221px] object-contain opacity-80 md:block"
				width="221"
				height="133"
				aria-hidden="true"
			/>

			<HeaderH2 id="about-sec3-heading" class="mx-auto max-w-[900px]">
				圧倒的<span class="text-(--main-text)">コスト差</span>
				<Fragment slot="summary">経営的に放置できないほどの差となります</Fragment>
			</HeaderH2>

			<div class="mx-auto mt-4 flex max-w-[900px] flex-col gap-6 md:flex-row md:items-center md:gap-6">
				<div class="flex-1">
					<HeaderH3 align="left">
						集客のチカラの広告運用は<span class="text-(--main-text)"> 完全定額制</span>
					</HeaderH3>
					<PDef>
						広告代理店の中間マージン、自社運用の専人材などの「見えないコスト」を排除することで、3年間試算
						（例）で
					</PDef>
					<p class="text-(--base-text)">
						<span class="text-[40px] leading-[60px] font-bold text-(--main-text)">360 </span>
						<span class="text-[40px] leading-[60px] font-bold">～</span>
						<span class="text-[40px] leading-[60px] font-bold text-(--main-text)"> 840</span>
						<span class="text-2xl leading-[60px] font-bold"> 万円</span>
						<span class="text-base leading-[60px]">もの圧倒的な差が生まれます。</span>
					</p>
				</div>
				<div class="shrink-0 md:w-[369px]">
					<img
						src="/images/graph-comparison_cost.png"
						alt="広告代理店と集客のチカラの運用コスト比較グラフ"
						class="w-full object-contain"
						width="369"
						height="266"
						loading="lazy"
					/>
				</div>
			</div>

			<CardDef class="relative mx-auto mt-6 max-w-[900px] overflow-hidden">
				<div class="flex flex-col md:flex-row">
					<div
						class="relative flex min-h-[120px] flex-col items-center justify-center bg-(--base-bg-lblue) p-(--pd-middle) md:w-[306px] md:shrink-0"
					>
						<span
							class="pointer-events-none absolute top-1/2 left-4 -translate-y-1/2 font-semibold text-[120px] leading-none text-(--main-bg-sub) md:left-6 md:text-[180px]"
							aria-hidden="true"
						>
							Q
						</span>
						<HeaderH3 align="center" class="relative z-10 pb-0">
							広告代理店の中間マージンは<br />必要なのか？
						</HeaderH3>
					</div>

					<div class="relative flex flex-1 flex-col justify-center gap-2 p-(--pd-middle) md:pr-36">
						<PDef class="pb-0 font-bold text-xl leading-6">{marginQaAnswer[0]}</PDef>
						<PDef>{marginQaAnswer[1]}</PDef>
						<PDef class="pb-0">{marginQaAnswer[2]}</PDef>
						<img
							src="/images/illust-human_OK.png"
							alt=""
							class="pointer-events-none absolute right-4 bottom-0 hidden h-[162px] w-[126px] object-cover md:block"
							width="126"
							height="162"
							aria-hidden="true"
						/>
					</div>
				</div>
			</CardDef>
		</div>
	</section>

	<!-- CTA（ページ中段） -->
	<CtaSection variant="contact-only" />

	<!-- 第4セクション -->
	<section
		class="relative overflow-hidden bg-(--base-bg-lblue) px-4 py-8 md:py-12"
		aria-labelledby="about-sec4-heading"
	>
		<div
			class="pointer-events-none absolute inset-0 bg-[url('/images/bg-office.jpg')] bg-cover bg-center opacity-5"
			aria-hidden="true"
		></div>

		<div class="relative mx-auto w-full max-w-(--container)">
			<HeaderH2 id="about-sec4-heading" class="mx-auto max-w-[900px]">
				削減額は、<span class="text-(--main-text)">複利を生み出す</span><br class="md:hidden" />成長エンジンへ
			</HeaderH2>

			<div class="relative mx-auto mt-4 flex max-w-[900px] flex-col gap-6 md:flex-row md:items-start md:gap-10">
				<div class="flex-1">
					<HeaderH3 align="left">集客のチカラが回す、４つのサイクル</HeaderH3>

					<div class="mb-4 flex flex-wrap items-center gap-1">
						{
							growthCycleSteps.map((step, index) => (
								<>
									<span class="flex h-10 min-w-[72px] items-center justify-center bg-(--main-bg) px-2 text-center text-base font-medium text-(--white) md:min-w-[100px] md:text-2xl md:leading-10">
										{step}
									</span>
									{index < growthCycleSteps.length - 1 && (
										<img
											src="/svg/arrow-right.svg"
											alt=""
											class="h-[22px] w-8 shrink-0 object-contain"
											width="32"
											height="22"
											aria-hidden="true"
										/>
									)}
								</>
							))
						}
					</div>

					<PDef>
						集客のチカラなら、運用コストの削減分が次の 投資原資に。新たな成果が次の投資を生み、事業成長が複利のように加速します。これが、
						「成長投資型」 の運用サイクルです。
					</PDef>
				</div>

				<div class="shrink-0 md:absolute md:top-[-92px] md:right-0 md:w-[238px]">
					<img
						src="/images/fig-4cycles.png"
						alt="運用による成長サイクルの図解"
						class="mx-auto w-full max-w-[238px] object-contain"
						width="238"
						height="214"
						loading="lazy"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- 第5セクション -->
	<section class="px-4 py-8 md:py-12" aria-labelledby="about-sec5-heading">
		<div class="mx-auto w-full max-w-(--container)">
			<HeaderH2 id="about-sec5-heading" class="mx-auto max-w-[900px]">
				同じ広告予算でも、<span class="text-(--main-text)">受注は増え続ける</span>
				<Fragment slot="summary">増えた利益で さらに事業成長へ</Fragment>
			</HeaderH2>

			<div class="mx-auto mt-6 flex max-w-[900px] flex-col gap-6 rounded-(--border-radius) bg-(--white) md:flex-row md:items-end md:gap-6">
				<div class="shrink-0 md:w-[391px]">
					<img
						src="/images/graph-estimate_order.png"
						alt="広告予算と受注数の推移グラフ"
						class="w-full object-contain"
						width="391"
						height="312"
						loading="lazy"
					/>
				</div>
				<div class="flex-1 pb-6 md:pb-9">
					<PDef class="pb-0">
						広告代理店とのコストの差額が、そのまま広告投下費の増加分に。 広告予算を増やさなくても、受注が積み上がります。
						さらに、増えた受注から得た利益を次の広告投資へ回せば、事業成長は "複利のように" 加速します。
					</PDef>
				</div>
			</div>
		</div>
	</section>

	<!-- 第6セクション -->
	<section
		class="relative bg-(--base-bg-lblue) px-4 pb-12 pt-6 md:pb-16 md:pt-8"
		aria-labelledby="about-sec6-heading"
	>
		<img
			src="/images/fig-apo.png"
			alt=""
			class="pointer-events-none absolute top-[-58px] right-4 hidden h-[126px] w-[140px] object-contain md:block"
			width="140"
			height="126"
			aria-hidden="true"
		/>

		<div class="mx-auto w-full max-w-(--container)">
			<HeaderH2 id="about-sec6-heading" class="mx-auto max-w-[900px]">
				<Fragment slot="lead">横並びの広告に、終止符を</Fragment>
				貴社<span class="text-(--main-text)">専用のポートフォリオ</span>運用へ
			</HeaderH2>

			<PDef class="mx-auto max-w-[900px] text-center">
				「APO」（AD Portfolio Optimizer）は、貴社の目的・目標に合わせて 媒体配分を「専用設計」する新しい WEB
				広告運用メソッドです
			</PDef>

			<SecPortfolio class="mx-auto mt-4 max-w-[900px]" />
		</div>
	</section>

	<!-- 第7セクション -->
	<section class="px-4 py-8 md:py-12" aria-labelledby="about-sec7-heading">
		<div class="mx-auto w-full max-w-(--container)">
			<HeaderH2 id="about-sec7-heading" class="mx-auto max-w-[900px]">
				<span class="text-(--main-text)">「圧倒的なコストダウン」</span>と<span class="text-(--main-text)"
					>「プロ運用」</span
				>で
				<Fragment slot="summary">貴社の WEB 広告の投資効率を、最大化します</Fragment>
			</HeaderH2>

			<div class="mx-auto mt-8 flex max-w-[900px] flex-col items-center gap-4 md:flex-row md:items-start md:justify-center md:gap-10">
				<ServicePlanButton variant="pro" />
				<ServicePlanButton variant="advisor" />
			</div>
		</div>
	</section>
</Layout>
