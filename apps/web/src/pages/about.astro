---
import Layout from "../layouts/Layout.astro";
import CtaSectionContact from "../components/sections/CtaSectionContact.astro";
import HeaderH2 from "../components/ui/HeaderH2.astro";
import HeaderH3 from "../components/ui/HeaderH3.astro";
import PDef from "../components/ui/PDef.astro";
import CardDef from "../components/ui/CardDef.astro";
import CardPicLeft from "../components/ui/CardPicLeft.astro";
import ServicePlanButton from "../components/ui/ServicePlanButton.astro";
import SecPortfolio from "../components/ui/SecPortfolio.astro";
import PageKeyVisual from "../components/sections/PageKeyVisual.astro";
import BtnServicePro from "../components/ui/BtnServicePro.astro";
import BtnServiceAdvisor from "../components/ui/BtnServiceAdvisor.astro";
---

<Layout title="集客のチカラとは | 集客のチカラ" breadcrumb="集客のチカラとは">
  <PageKeyVisual>
    <p class="text-sm md:text-base text-center font-semibold pt-2 pb-2 md:pb-6 text-(--main-bg-sub)">Growth Asset Advertising</p>
    <h1 id="about-kv-heading" class="pb-4 md:pb-6 text-3xl leading-10 text-center font-semibold text-(--white) md:text-4xl tracking-widest">「成長投資型」の<br class="md:hidden" />広告運用へ</h1>
    <div class="text-sm md:text-base md:text-center pb-6 md:pb-4">
      <PDef class="text-(--white)"
        >従来の WEB 広告運用は、中間マージンや過剰な運用コストが、事業成長の " 足枷 " になっていました<br />私たちはこのコスト構造を一新し、広告を " コスト" から" 複利を生む成長投資 " へと変えます</PDef
      >
    </div>
  </PageKeyVisual>

  <!-- 第1セクション -->
  <section class="px-4 pb-10 pt-6 md:pb-16" aria-labelledby="about-sec1-heading">
    <div class="relative mx-auto w-full max-w-(--container)">
      <HeaderH2 id="about-sec1-heading" class="mx-auto max-w-[900px]">
        <Fragment slot="lead">WEB 広告の運用 2 つの選択肢には</Fragment>
        <span class="text-(--main-text)">大きな課題</span>がありました
      </HeaderH2>

      <img
        src="/images/illust-human_think.png"
        alt="困っている人のイラスト"
        class="mx-auto pointer-events-none md:absolute md:top-[-10px] md:right-[25px] w-[120px] object-cover z-10"
        width="147"
        height="127"
        aria-hidden="true"
      />

      <div class="relative mx-auto flex flex-col gap-3 md:flex-row md:gap-4 z-20">
        <CardPicLeft image="/images/illust-advertising_agency.png" imageAlt="広告代理店のイラスト" title="広告代理店" class="flex-1">
          <p>・広告費の 約 20% が、中間マージンとして消える。<br />・広告費が増えるほど、コストも比例して膨らむ。</p>
        </CardPicLeft>
        <CardPicLeft image="/images/illust-staff_silhouette.png" imageAlt="自社運用のイラスト" title="自社運用" class="flex-1">
          <p>・専門人材の雇用が固定費として圧迫している。<br />・ナレッジの蓄積と教育に、時間とコストがかる。</p>
        </CardPicLeft>
      </div>
    </div>
  </section>

  <!-- 第2セクション -->
  <section class="relative bg-(--base-bg-lblue) px-4 pb-10 pt-10 md:pt-16" aria-labelledby="about-sec2-heading">
    <div class="pointer-events-none absolute top-[-60px] md:top-[-45px] left-1/2 -translate-x-1/2">
      <img src="/svg/arrow-down.svg" alt="" class="size-[90px] md:size-[90px]" width="80" height="80" aria-hidden="true" />
    </div>

    <div class="relative mx-auto w-full max-w-(--container)">
      <img
        src="/images/pic-graph_up.png"
        alt="収益アップのイメージ図"
        class="pointer-events-none absolute top-[-80px] md:top-[-100px] right-0 md:right-4 w-[90px] md:w-[150px] object-cover"
        width="158"
        height="158"
        aria-hidden="true"
      />

      <HeaderH2 id="about-sec2-heading" class="pt-2 md:pt-0">
        <Fragment slot="lead">その課題を解決するため</Fragment>
        広告運用コストの<br class="md:hidden" /><span class="text-(--main-text)">「常識」を変えます</span>！
      </HeaderH2>

      <div class="mx-auto flex flex-col gap-3 md:flex-row md:gap-4">
        <CardPicLeft image="/images/illust-int_zero.png" imageAlt="ゼロのイラスト" class="flex-1">
          <Fragment slot="title">
            中間マージン不要、<span class="text-(--main-text)">ゼロ</span>に！
          </Fragment>
          <p>広告費に比例して増える 手数料を排除し、<br class="hidden md:block" />運用コストを大幅削減。</p>
        </CardPicLeft>
        <CardPicLeft image="/images/illust-calendar.png" imageAlt="カレンダーのイラスト" class="flex-1">
          <Fragment slot="title">
            毎月の運用費を、<span class="text-(--main-text)">定額制</span>に！
          </Fragment>
          <p>広告費に連動しない 料金体系で、<br />削減分を 貴社の成長投資へ。</p>
        </CardPicLeft>
      </div>
    </div>
  </section>

  <!-- 第3セクション -->
  <section id="sec3" class="relative pb-12 pt-8 md:pt-10" aria-labelledby="about-sec3-heading">
    <svg class="pointer-events-none absolute inset-x-0 top-0 z-20 block h-10 w-full select-none" viewBox="0 0 1280 29" preserveAspectRatio="none" aria-hidden="true">
      <path fill="var(--base-bg-lblue)" d="M0,0v29C52.4,16.6,319,7.2,640,7.2s587.6,9.4,640,21.8V0H0Z"></path>
    </svg>

    <div class="relative mx-auto w-full max-w-(--container) px-4">
      <HeaderH2 id="about-sec3-heading" class="mx-auto max-w-[900px]">
        圧倒的<span class="text-(--main-text)">コスト差</span>
        <Fragment slot="summary">経営的に放置できないほどの差となります</Fragment>
      </HeaderH2>

      <img
        src="/images/illust-human_gather.png"
        alt="オフィスのイメージ図"
        class="pointer-events-none mx-auto lg:absolute top-0 left-0 h-[133px] w-[221px] object-contain"
        width="221"
        height="133"
        aria-hidden="true"
      />

      <div class="mx-auto mt-4 flex flex-col gap-6 md:flex-row md:items-center md:gap-6">
        <div class="flex-1">
          <HeaderH3 align="left">
            集客のチカラの広告運用は<br class="md:hidden" /><span class="text-(--main-text)"> 完全定額制</span>
          </HeaderH3>
          <PDef> 広告代理店の中間マージン、自社運用の専人材などの「見えないコスト」を排除することで、3年間試算 （例）で </PDef>
          <p class="text-(--base-text)">
            <span class="text-[40px] leading-[60px] font-bold text-(--main-text)">360</span>
            <span class="text-[30px] leading-[60px] font-bold">～</span>
            <span class="text-[40px] leading-[60px] font-bold text-(--main-text)">840</span>
            <span class="text-2xl leading-[60px] font-bold pl-1">万円<br class="md:hidden" /></span>
            <span class="text-base leading-[60px]">もの圧倒的な差が生まれます。</span>
          </p>
        </div>
        <div class="shrink-0 md:w-[369px]">
          <img src="/images/graph-estimate_cost.png" alt="広告代理店と集客のチカラの運用コスト比較グラフ" class="w-full object-contain" width="369" height="266" loading="lazy" />
        </div>
      </div>

      <CardDef class="relative mx-auto mt-6 max-w-(--container) overflow-hidden">
        <div class="flex flex-col md:flex-row">
          <div class="relative flex min-h-[90px] flex-col items-center justify-center bg-(--base-bg-lblue) md:w-[306px] md:shrink-0">
            <img
              src="/images/fig-text-q.png"
              alt="Qのテキスト"
              class="pointer-events-none absolute top-[-20px] md:top-[20px] left-[-20px] w-[80px] md:w-[126px]"
              width="126"
              height="162"
              aria-hidden="true"
            />
            <h3 class="relative z-10 p-4 text-lg leading-8 font-bold">
              広告代理店の中間マージンは<br />必要なのか？
            </h3>
          </div>

          <div class="relative pt-5 pl-5 pr-5 md:pb-5 md:pr-[150px]">
            <p class="font-bold text-xl leading-6 pb-3">"いいえ、必要ありません"</p>
            <PDef>中間マージンは、元々「マスメディア時代のモデル」。 広告費に比例して手数料が増えるコスト構造は、「世界の常識」とかけ離れた仕組みです。</PDef>
            <PDef>旧時代の仕組みを、根本から変えます</PDef>
            <div class="pointer-events-none ml-auto w-[80px] md:w-[100px] pt-3 md:absolute md:right-3 md:bottom-0 md:pt-0">
              <img src="/images/illust-human_OK.png" alt="OKポーズの男性" class="w-full object-cover" width="126" height="162" aria-hidden="true" />
            </div>
          </div>
        </div>
      </CardDef>
    </div>
  </section>

  <!-- CTA（ページ中段） -->
  <section class="cta-section flex flex-col overflow-hidden" aria-labelledby="cta-contact-heading">
    <CtaSectionContact />
  </section>

  <!-- 第4セクション -->
  <section class="relative overflow-hidden bg-(--base-bg-lblue) px-4 py-8 md:py-12" aria-labelledby="about-sec4-heading">
    <img
      src="/images/bg-office.jpg"
      alt=""
      class="pointer-events-none absolute inset-0 size-full object-cover object-center opacity-30 select-none"
      aria-hidden="true"
      draggable="false"
      loading="lazy"
    />

    <div class="relative mx-auto w-full max-w-(--container)">
      <HeaderH2 id="about-sec4-heading" class="mx-auto max-w-[900px]">
        削減額は、<span class="text-(--main-text)">複利を生み出す</span><br />成長エンジンへ
      </HeaderH2>

      <div class="relative mx-auto mt-4 flex flex-col gap-6 md:flex-row md:items-start md:gap-10">
        <div class="flex-1">
          <HeaderH3 align="left">集客のチカラが回す、４つのサイクル</HeaderH3>

          <div class="mb-4 flex flex-wrap items-center gap-1">
            <span class="flex items-center justify-center bg-(--main-bg) px-4 py-1 text-center text-base text-sm text-(--white) md:min-w-[100px] md:text-xl">削減</span>
            <img src="/svg/arrow-right.svg" alt="" class="h-[22px] w-4 shrink-0 object-contain md:w-8" width="32" height="22" aria-hidden="true" />
            <span class="flex items-center justify-center bg-(--main-bg) px-4 py-1 text-center text-base text-sm text-(--white) md:min-w-[100px] md:text-xl">投資</span>
            <img src="/svg/arrow-right.svg" alt="" class="h-[22px] w-4 shrink-0 object-contain md:w-8" width="32" height="22" aria-hidden="true" />
            <span class="flex items-center justify-center bg-(--main-bg) px-4 py-1 text-center text-base text-sm text-(--white) md:min-w-[100px] md:text-xl">成果</span>
            <img src="/svg/arrow-right.svg" alt="" class="h-[22px] w-4 shrink-0 object-contain md:w-8" width="32" height="22" aria-hidden="true" />
            <span class="flex items-center justify-center bg-(--main-bg) px-4 py-1 text-center text-base text-sm text-(--white) md:min-w-[100px] md:text-xl">成長</span>
          </div>

          <PDef> 集客のチカラなら、運用コストの削減分が次の 投資原資に。新たな成果が次の投資を生み、事業成長が複利のように加速します。これが、 「成長投資型」 の運用サイクルです。 </PDef>
        </div>

        <div class="shrink-0 md:absolute md:bottom-[80px] md:right-0 md:w-[200px]">
          <img src="/images/fig-4cycles.png" alt="運用による成長サイクルの図解" class="mx-auto w-full max-w-[200px] object-contain" width="238" height="214" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 第5セクション -->
  <section class="px-4 py-8 md:py-12" aria-labelledby="about-sec5-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="about-sec5-heading" class="mx-auto">
        同じ広告予算でも、<br class="md:hidden" /><span class="text-(--main-text)">受注は増え続ける</span>
        <Fragment slot="summary">増えた利益でさらに事業成長へ</Fragment>
      </HeaderH2>

      <div class="mx-auto flex flex-col gap-6 rounded-(--border-radius) bg-(--white) md:flex-row md:items-start md:gap-6">
        <div class="shrink-0 md:w-[391px]">
          <img src="/images/graph-estimate_order.png" alt="広告予算と受注数の推移グラフ" class="w-full object-contain" width="391" height="312" loading="lazy" />
        </div>
        <div class="flex-1 pb-6 md:pb-9">
          <PDef class="pb-0">
            広告代理店とのコストの差額が、そのまま広告投下費の増加分に。 広告予算を増やさなくても、受注が積み上がります。 さらに、増えた受注から得た利益を次の広告投資へ回せば、事業成長は
            "複利のように" 加速します。
          </PDef>
        </div>
      </div>
    </div>
  </section>

  <!-- 第6セクション -->
  <section id="sec6" class="relative bg-(--base-bg-lblue) px-4 pb-12 pt-6 md:pb-16 md:pt-8" aria-labelledby="about-sec6-heading">
    <svg class="pointer-events-none absolute inset-x-0 top-0 z-20 block h-10 w-full select-none" viewBox="0 0 1280 29" preserveAspectRatio="none" aria-hidden="true">
      <path fill="var(--white)" d="M0,0v29C52.4,16.6,319,7.2,640,7.2s587.6,9.4,640,21.8V0H0Z"></path>
    </svg>
    <div class="relative mx-auto w-full max-w-(--container)">
      <img
        src="/images/fig-apo.png"
        alt="「APO」（AD Portfolio Optimizer）"
        class="pointer-events-none mx-auto pb-4 md:absolute top-[-56px] right-4 h-auto w-[120px] object-contain md:block z-30"
        width="140"
        height="126"
        aria-hidden="true"
      />
      <HeaderH2 id="about-sec6-heading" class="mx-auto max-w-[900px] pt-4">
        <Fragment slot="lead">横並びの広告に、終止符を</Fragment>
        貴社<span class="text-(--main-text)">専用の<br class="md:hidden" />ポートフォリオ</span>運用へ
      </HeaderH2>
      <PDef class="mx-auto text-center">
        「APO」（AD Portfolio Optimizer）は、貴社の目的・目標に合わせて<br class="hidden md:block" />媒体配分を「専用設計」する新しい WEB 広告運用メソッドです
      </PDef>

      <SecPortfolio class="mx-auto mt-4 max-w-[900px]" />
    </div>
  </section>

  <!-- 第7セクション -->
  <section class="px-4 py-8 md:py-12 relative" aria-labelledby="about-sec7-heading">
    <svg class="pointer-events-none absolute top-0 left-0 z-10 block h-[68px] w-auto select-none hidden md:block" viewBox="0 0 408 68" aria-hidden="true">
      <path fill="var(--base-bg-lblue)" d="M112.1,21.8C9.1,46.5,1.9,62.2,0,68V0h408c-46.8,3.6-189.9-3.6-295.9,21.8Z"></path>
    </svg>
    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="about-sec7-heading" class="mx-auto max-w-[900px]">
        <span class="text-(--main-text)">「圧倒的なコストダウン」</span>と<span class="text-(--main-text)">「プロ運用」</span>で
        <Fragment slot="summary">貴社のWEB広告の投資効率を、最大化します</Fragment>
      </HeaderH2>

      <div class="mx-auto flex flex-col items-center gap-4 md:flex-row md:items-stretch md:justify-center md:gap-10">
        <BtnServicePro />
        <BtnServiceAdvisor />
      </div>
    </div>
  </section>
</Layout>
