---
import Layout from "../layouts/Layout.astro";
import KeyVisual from "../components/sections/PageKeyVisualTop.astro";
import HeaderH2 from "../components/ui/HeaderH2.astro";
import HeaderH3 from "../components/ui/HeaderH3.astro";
import PDef from "../components/ui/PDef.astro";
import CardDef from "../components/ui/CardDef.astro";
import BtnLink from "../components/ui/BtnLink.astro";
import BtnServicePro from "../components/ui/BtnServicePro.astro";
import BtnServiceAdvisor from "../components/ui/BtnServiceAdvisor.astro";
import ContactForm from "../components/sections/ContactForm.astro";
import CtaSectionIntro from "../components/sections/CtaSectionIntro.astro";
import { problems, solutions, features, teamRoles } from "../data/home";

const problemSolutionPairs = problems.map((problem, index) => ({
  problem,
  solution: solutions[index]!,
}));
---

<Layout showCtaSectionIntro={false} showCtaSectionContact={false}>
  <KeyVisual />

  <section class="section-problem px-4 pb-10" aria-labelledby="section-problem-heading">
    <div class="mx-auto w-full max-w-(--container)">
      <div class="mx-auto max-w-[900px]">
        <HeaderH2 id="section-problem-heading" class="mx-auto max-w-[900px]">
          <Fragment slot="lead">貴社の WEB 広告運用の</Fragment>
          <span class="text-(--main-text)">悩みや不安</span>を解決します!
        </HeaderH2>
      </div>

      <!-- スマートフォン -->
      <div class="relative mx-auto flex w-full max-w-[360px] flex-col items-center md:hidden">
        <div class="relative flex w-full flex-col gap-2 overflow-visible rounded-(--border-radius) bg-(--base-bg-lgray) px-4 pb-4">
          <div class="relative z-10 flex h-20 items-start justify-end pb-5">
            <h3 class="w-[209px] pl-10 pt-6 text-base leading-6 font-bold text-(--base-text)">
              このようなお悩み<br />ありませんか？
            </h3>
          </div>

          <ul class="relative flex flex-col gap-2">
            {
              problems.map(({ image, text }, index) => (
                <li class="relative">
                  {index === 0 && (
                    <img
                      src="/images/pic-man_worry.png"
                      alt=""
                      class="pointer-events-none absolute top-[-80px] left-[5px] z-0 h-[93px] w-[110px] object-cover object-top"
                      width="110"
                      height="93"
                      aria-hidden="true"
                    />
                  )}
                  <div class:list={["flex items-center gap-4 rounded-(--border-radius) border border-(--border) bg-(--white) pl-3 pr-2 py-2.5", index === 0 && "relative z-10"]}>
                    <img src={image} alt="" class="size-11 shrink-0 object-contain" width="45" height="45" />
                    <p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">{text}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="flex h-[59px] w-20 shrink-0 flex-col items-center overflow-hidden px-4 pb-4">
          <img src="/svg/arrow-down.svg" alt="" class="size-20" width="80" height="80" aria-hidden="true" />
        </div>

        <div class="flex w-full flex-col gap-2 rounded-(--border-radius) bg-(--base-bg-lblue) pb-4">
          <div class="relative flex h-[95px] shrink-0 items-start justify-center pb-5">
            <div class="flex flex-1 items-center rounded-t-(--border-radius) bg-(--main-bg) py-4">
              <h3 class="w-[232px] text-center text-lg leading-7 font-bold text-(--white)">
                "集客のチカラ" に<br />おまかせください
              </h3>
            </div>
            <img src="/images/pic-woman-cta.png" alt="" class="pointer-events-none absolute top-[-29px] right-0 h-[116px] w-[94px] object-cover" width="94" height="116" aria-hidden="true" />
          </div>

          <ul class="flex flex-col gap-2 px-4">
            {
              solutions.map(({ title, subtitle }) => (
                <li class="relative flex w-full items-center justify-center">
                  <div class="flex w-full items-center justify-end rounded-(--border-radius) border border-(--border) bg-(--white) px-4 pt-2.5 pb-2">
                    <p class="min-h-12 flex-1 text-center">
                      <span class="block text-lg leading-[21px] font-bold text-(--base-text) pb-[0.2rem]">{title}</span>
                      <span class="block text-sm leading-[21px] text-(--base-text)">{subtitle}</span>
                    </p>
                  </div>
                  <img src="/svg/icon-check.svg" alt="" class="absolute top-[21.5px] left-[18px] size-[25px]" width="25" height="25" aria-hidden="true" />
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- タブレット・PC -->
      <div class="relative mx-auto mt-4 hidden max-w-[900px] md:block">
        <img
          src="/images/pic-man_worry.png"
          alt=""
          class="pointer-events-none absolute top-[-118px] left-[20px] z-0 h-32 w-[180px] object-cover object-top"
          width="180"
          height="128"
          aria-hidden="true"
        />
        <img src="/images/pic-woman-cta.png" alt="" class="pointer-events-none absolute top-[-120px] right-[20px] z-0 h-[170px] w-[137px] object-cover" width="137" height="170" aria-hidden="true" />

        <div class="relative z-10 grid md:grid-cols-[minmax(0,1fr)_63px_minmax(0,1fr)]">
          <div class="rounded-t-(--border-radius) bg-(--base-bg-lgray) px-4 pt-6 pb-4">
            <h3 class="text-center text-base text-lg leading-6 font-bold text-(--base-text)">このようなお悩みありませんか？</h3>
          </div>
          <div aria-hidden="true"></div>
          <div class="overflow-hidden rounded-t-(--border-radius) bg-(--base-bg-lblue)">
            <div class="bg-(--main-bg) px-4 py-4">
              <h3 class="text-center text-base text-lg leading-6 font-bold text-(--white)">"集客のチカラ" におまかせください</h3>
            </div>
          </div>

          {
            problemSolutionPairs.map(({ problem, solution }, index) => (
              <>
                <div class:list={["bg-(--base-bg-lgray) px-4 pb-2", index === problemSolutionPairs.length - 1 ? "rounded-b-(--border-radius) pb-4" : "pb-0"]}>
                  <div class="flex h-full items-center gap-4 rounded-(--border-radius) border border-(--border) bg-(--white) px-[15px] py-2.5">
                    <img src={problem.image} alt="" class="size-11 shrink-0 object-contain" width="45" height="45" />
                    <p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">{problem.text}</p>
                  </div>
                </div>

                <div class="flex items-center justify-center">
                  <img src="/svg/arrow-right.svg" alt="" class="h-10 w-16 object-contain" width="63" height="41" aria-hidden="true" />
                </div>

                <div class:list={["bg-(--base-bg-lblue) px-4 pb-2", index === problemSolutionPairs.length - 1 ? "rounded-b-(--border-radius) pb-4" : "pb-0"]}>
                  <div class="relative flex h-full items-center justify-center rounded-(--border-radius) border border-(--border) bg-(--white) px-4 py-2.5">
                    <img src="/svg/icon-check.svg" alt="" class="absolute top-1/2 left-[18px] size-6 -translate-y-1/2" width="25" height="25" aria-hidden="true" />
                    <p class="text-center">
                      <span class="block text-xl leading-[21px] font-bold text-(--base-text) pb-1">{solution.title}</span>
                      <span class="block text-sm leading-[21px] text-(--base-text)">{solution.subtitle}</span>
                    </p>
                  </div>
                </div>
              </>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-features relative bg-(--base-bg-lblue) pb-16" aria-labelledby="section-features-heading">
    <svg class="pointer-events-none absolute inset-x-0 top-[-5px] z-20 block h-10 w-full" viewBox="0 0 1280 29" preserveAspectRatio="none" aria-hidden="true">
      <path fill="#fff" d="M0,0v29C52.4,16.6,319,7.2,640,7.2s587.6,9.4,640,21.8V0H0Z"></path>
    </svg>

    <img src="/svg/vector-bottom_right.svg" alt="" class="pointer-events-none absolute right-0 bottom-0 z-10 block select-none" draggable="false" aria-hidden="true" loading="lazy" />

    <div class="px-4 pt-12 md:pt-16">
      <div class="mx-auto w-full max-w-(--container)">
        <HeaderH2 id="section-features-heading" class="mx-auto">
          <span>集客のチカラ</span><span class="text-(--main-text)">４つの特徴</span>
        </HeaderH2>

        <div class="pt-2 grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-4">
          {
            features.map((feature) => (
              <CardDef class="relative flex flex-col items-center px-2 py-6 md:px-10 md:py-6">
                <img src="/svg/icon-check.svg" alt="" class="absolute top-3.5 left-3.5 size-6" width="25" height="25" aria-hidden="true" />

                <div class="flex h-[100px] items-center justify-center">
                  <img src={feature.image} alt={feature.imageAlt} class="max-h-[111px] w-auto max-w-full object-contain" width="111" height="111" loading="lazy" />
                </div>

                <div class="flex w-full flex-col items-center gap-2.5 pt-4 pb-2 text-center">
                  <h3 class="text-xl leading-6 font-bold text-(--base-text)">{feature.title}</h3>
                  <p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">{feature.description}</p>
                </div>

                {feature.href && <BtnLink href={feature.href} class="mt-2" />}
              </CardDef>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-plans relative overflow-hidden px-4 pt-9" aria-labelledby="section-plans-heading">
    <svg class="pointer-events-none absolute top-0 left-0 z-10 block h-[68px] w-auto select-none hidden md:block" viewBox="0 0 408 68" aria-hidden="true">
      <path fill="var(--base-bg-lblue)" d="M112.1,21.8C9.1,46.5,1.9,62.2,0,68V0h408c-46.8,3.6-189.9-3.6-295.9,21.8Z"></path>
    </svg>

    <div class="mx-auto w-full max-w-(--container)">
      <HeaderH2 id="section-plans-heading" class="mx-auto max-w-[900px]">
        <span class="text-(--main-text)">「圧倒的なコストダウン」</span>と<br class="md:hidden" /><span class="text-(--main-text)">「プロ運用」</span>で
        <Fragment slot="summary">貴社のWEB広告の投資効率を、最大化します</Fragment>
      </HeaderH2>

      <div class="mx-auto pb-10 flex max-w-[900px] flex-col items-center gap-4 md:flex-row md:items-stretch md:justify-center lg:gap-10">
        <BtnServicePro />
        <BtnServiceAdvisor />
      </div>

      <button type="button" class="block mx-auto max-w-[600px] rounded-(--border-radius) overflow-hidden shadow-[0_2px_1px_rgba(0,0,0,0.25)]" @click="alert('まだLPがない状況です')">
        <img src="/images/banner-meo.png" alt="集客のチカラMEO" class="pointer-events-none w-full object-contain" width="600" height="140" loading="lazy" />
      </button>

      <div class="relative mx-auto max-w-[900px] pt-12">
        <div class="relative z-10 max-w-[610px]">
          <HeaderH3 align="left">
            WEB広告に特化した<span class="text-(--main-text)">プロチームが集結</span>
          </HeaderH3>

          <PDef> 上場企業から個人経営まで。多業種での豊富な運用実績を持つ精鋭チーム。AI任せではない、経験に基づいた「生きた知見」で貴社を支えます。 </PDef>

          <div class="flex flex-col gap-2 md:flex-row md:flex-wrap">
            {
              teamRoles.map(({ lead, title }) => (
                <div class="w-full border border-(--border) bg-(--white) p-3 text-center md:max-w-[200px] md:flex-1">
                  <p class="text-sm leading-5 text-(--base-text)">
                    {lead}
                    <br />
                    <span class="font-bold">{title}</span>
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
      <div class="pt-6 w-full md:h-[240px] relative">
        <img
          src="/images/pic-meeting.png"
          alt="会議をするチームの写真"
          class="pointer-events-none block w-full opacity-70 md:absolute md:w-[600px] md:right-[-25px] md:bottom-[-120px]"
          width="578"
          height="329"
          loading="lazy"
        />
      </div>
    </div>
  </section>
  <section class="bg-(--main-bg-sub) pt-3 pb-20">
    <CtaSectionIntro/>
    <ContactForm variant="pro-light" sectionId="home-contact-form" />
  </section>
</Layout>
