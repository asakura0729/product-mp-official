---
import Layout from '../layouts/Layout.astro';
import KeyVisual from '../components/sections/KeyVisual.astro';
import SectionPlans from '../components/sections/SectionPlans.astro';
import HeaderH2 from '../components/ui/HeaderH2.astro';
import CardDef from '../components/ui/CardDef.astro';
import BtnLink from '../components/ui/BtnLink.astro';
import { problems, solutions, features } from '../data/home';

const problemSolutionPairs = problems.map((problem, index) => ({
	problem,
	solution: solutions[index]!,
}));
---

<Layout title="集客のチカラ">
	<KeyVisual />

	<section class="section-problem px-4 pb-10 md:pb-16" aria-labelledby="section-problem-heading">
		<div class="mx-auto w-full max-w-(--container)">
			<div class="mx-auto max-w-[900px]">
				<HeaderH2 id="section-problem-heading" class="mx-auto max-w-[900px]">
					<Fragment slot="lead">貴社の WEB 広告運用の</Fragment>
					<span class="text-(--main-text)">悩みや不安</span>を解決します!
				</HeaderH2>
			</div>

			<!-- スマートフォン -->
			<div class="relative mx-auto flex w-full max-w-[360px] flex-col items-center md:hidden">
				<div class="relative flex w-full flex-col gap-2 overflow-visible rounded-(--border-radius) bg-(--base-bg-lgray) px-4 pb-4">
					<div class="relative z-10 flex h-20 items-start justify-end pb-5">
						<h3 class="w-[209px] pl-10 pt-6 text-base leading-6 font-bold text-(--base-text)">
							このようなお悩み<br />ありませんか？
						</h3>
					</div>

					<ul class="relative flex flex-col gap-2">
						{
							problems.map(({ image, text }, index) => (
								<li class="relative">
									{index === 0 && (
										<img
											src="/images/pic-man_worry.png"
											alt=""
											class="pointer-events-none absolute top-[-80px] left-[5px] z-0 h-[93px] w-[110px] object-cover object-top"
											width="110"
											height="93"
											aria-hidden="true"
										/>
									)}
									<div
										class:list={[
											'flex items-center gap-4 rounded-(--border-radius) border border-(--border) bg-(--white) pl-3 pr-2 py-2.5',
											index === 0 && 'relative z-10',
										]}
									>
										<img src={image} alt="" class="size-11 shrink-0 object-contain" width="45" height="45" />
										<p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">{text}</p>
									</div>
								</li>
							))
						}
					</ul>
				</div>

				<div class="flex h-[59px] w-20 shrink-0 flex-col items-center overflow-hidden px-4 pb-4">
					<img
						src="/svg/arrow-down.svg"
						alt=""
						class="size-20"
						width="80"
						height="80"
						aria-hidden="true"
					/>
				</div>

				<div class="flex w-full flex-col gap-2 rounded-(--border-radius) bg-(--base-bg-lblue) pb-4">
					<div class="relative flex h-[95px] shrink-0 items-start justify-center pb-5">
						<div class="flex flex-1 items-center rounded-t-(--border-radius) bg-(--main-bg) py-4">
							<h3 class="w-[232px] text-center text-lg leading-7 font-bold text-(--white)">
								"集客のチカラ" に<br />おまかせください
							</h3>
						</div>
						<img
							src="/images/pic-woman-cta.png"
							alt=""
							class="pointer-events-none absolute top-[-29px] right-0 h-[116px] w-[94px] object-cover"
							width="94"
							height="116"
							aria-hidden="true"
						/>
					</div>

					<ul class="flex flex-col gap-2 px-4">
						{
							solutions.map(({ title, subtitle }) => (
								<li class="relative flex w-full items-center justify-center">
									<div class="flex w-full items-center justify-end rounded-(--border-radius) border border-(--border) bg-(--white) px-4 pt-2.5 pb-2">
										<p class="min-h-12 flex-1 text-center">
											<span class="block text-lg leading-[21px] font-bold text-(--base-text) pb-[0.2rem]">{title}</span>
											<span class="block text-sm leading-[21px] text-(--base-text)">{subtitle}</span>
										</p>
									</div>
									<img
										src="/svg/icon-check.svg"
										alt=""
										class="absolute top-[21.5px] left-[18px] size-[25px]"
										width="25"
										height="25"
										aria-hidden="true"
									/>
								</li>
							))
						}
					</ul>
				</div>
			</div>

			<!-- タブレット・PC -->
			<div class="relative mx-auto mt-4 hidden max-w-[900px] md:block">
				<img
					src="/images/pic-man_worry.png"
					alt=""
					class="pointer-events-none absolute top-[-118px] left-[20px] z-0 h-32 w-[180px] object-cover object-top"
					width="180"
					height="128"
					aria-hidden="true"
				/>
				<img
					src="/images/pic-woman-cta.png"
					alt=""
					class="pointer-events-none absolute top-[-120px] right-[20px] z-0 h-[170px] w-[137px] object-cover"
					width="137"
					height="170"
					aria-hidden="true"
				/>

				<div
					class="relative z-10 grid md:grid-cols-[minmax(0,1fr)_63px_minmax(0,1fr)]"
				>
				<div class="rounded-t-(--border-radius) bg-(--base-bg-lgray) px-4 pt-6 pb-4">
					<h3 class="text-center text-base text-lg leading-6 font-bold text-(--base-text)">
						このようなお悩みありませんか？
					</h3>
				</div>
				<div aria-hidden="true"></div>
				<div class="overflow-hidden rounded-t-(--border-radius) bg-(--base-bg-lblue)">
					<div class="bg-(--main-bg) px-4 py-4">
						<h3 class="text-center text-base text-lg leading-6 font-bold text-(--white) ">
							"集客のチカラ" におまかせください
						</h3>
					</div>
				</div>

				{
					problemSolutionPairs.map(({ problem, solution }, index) => (
						<>
							<div
								class:list={[
									'bg-(--base-bg-lgray) px-4 pb-2',
									index === problemSolutionPairs.length - 1 ? 'rounded-b-(--border-radius) pb-4' : 'pb-0',
								]}
							>
								<div class="flex h-full items-center gap-4 rounded-(--border-radius) border border-(--border) bg-(--white) px-[15px] py-2.5">
									<img
										src={problem.image}
										alt=""
										class="size-11 shrink-0 object-contain"
										width="45"
										height="45"
									/>
									<p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">{problem.text}</p>
								</div>
							</div>

							<div class="flex items-center justify-center">
								<img
									src="/svg/arrow-right.svg"
									alt=""
									class="h-10 w-16 object-contain"
									width="63"
									height="41"
									aria-hidden="true"
								/>
							</div>

							<div
								class:list={[
									'bg-(--base-bg-lblue) px-4 pb-2',
									index === problemSolutionPairs.length - 1 ? 'rounded-b-(--border-radius) pb-4' : 'pb-0',
								]}
							>
								<div class="relative flex h-full items-center justify-center rounded-(--border-radius) border border-(--border) bg-(--white) px-4 py-2.5">
									<img
										src="/svg/icon-check.svg"
										alt=""
										class="absolute top-1/2 left-[18px] size-6 -translate-y-1/2"
										width="25"
										height="25"
										aria-hidden="true"
									/>
									<p class="text-center">
										<span class="block text-xl leading-[21px] font-bold text-(--base-text) pb-1">
											{solution.title}
										</span>
										<span class="block text-sm leading-[21px] text-(--base-text)">
											{solution.subtitle}
										</span>
									</p>
								</div>
							</div>
						</>
					))
				}
				</div>
			</div>
		</div>
	</section>

	<section
		class="section-features relative bg-(--base-bg-lblue) px-4 pt-12 pb-16 md:pt-16"
		aria-labelledby="section-features-heading"
	>
		<div class="mx-auto w-full max-w-(--container)">
			<HeaderH2 id="section-features-heading" class="mx-auto">
				<span>集客のチカラ</span><span class="text-(--main-text)">４つの特徴</span>
			</HeaderH2>

			<div class="pt-2 grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-6">
				{
					features.map((feature) => (
						<CardDef class="relative flex flex-col items-center px-2 py-6 md:px-10 md:py-6">
							<img
								src="/svg/icon-check.svg"
								alt=""
								class="absolute top-3.5 left-3.5 size-6"
								width="25"
								height="25"
								aria-hidden="true"
							/>

							<div class="flex h-[100px] items-center justify-center pb-4">
								<img
									src={feature.image}
									alt={feature.imageAlt}
									class="max-h-[111px] w-auto max-w-full object-contain"
									width="111"
									height="111"
									loading="lazy"
								/>
							</div>

							<div class="flex w-full flex-col items-center gap-2.5 pb-2 text-center">
								<h3 class="text-xl leading-6 font-bold text-(--base-text)">{feature.title}</h3>
								<p class="text-sm leading-[22px] whitespace-pre-line text-(--base-text)">
									{feature.description}
								</p>
							</div>

							{feature.href && <BtnLink href={feature.href} class="mt-2" />}
						</CardDef>
					))
				}
			</div>
		</div>
	</section>

	<SectionPlans />
</Layout>
