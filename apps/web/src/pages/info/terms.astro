---
import Layout from "../../layouts/Layout.astro";
import PageKeyVisual from "../../components/sections/PageKeyVisual.astro";
import HeaderH1 from "../../components/ui/HeaderH1.astro";
import { Content as SitePolicyContent } from "../../components/documents/site-policy.md";
---

<Layout
  title="利用規約"
  metaDescription="集客のチカラの利用規約です。当サイトのご利用にあたっての著作権、免責事項、外部リンクなどについて定めています。"
>
  <PageKeyVisual>
    <HeaderH1>利用規約</HeaderH1>
  </PageKeyVisual>

  <section class="px-4 pt-6 pb-8 md:pb-10" aria-label="利用規約">
    <div
      class="document-content mx-auto w-full max-w-(--container) text-sm leading-6 text-(--base-text) md:text-base"
    >
      <SitePolicyContent />
    </div>
  </section>
</Layout>
