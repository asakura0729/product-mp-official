---
import Layout from "../../layouts/Layout.astro";
import PageKeyVisual from "../../components/sections/PageKeyVisual.astro";
import HeaderH1 from "../../components/ui/HeaderH1.astro";
import { Content as PrivacyPolicyContent } from "../../components/documents/privacy-policy.md";
---

<Layout title="プライバシーポリシー" breadcrumb="プライバシーポリシー">
  <PageKeyVisual>
    <HeaderH1>プライバシーポリシー</HeaderH1>
  </PageKeyVisual>

  <section class="px-4 pt-6 pb-8 md:pb-10" aria-label="プライバシーポリシー">
    <div
      class="document-content mx-auto w-full max-w-(--container) text-sm leading-6 text-(--base-text) md:text-base"
    >
      <PrivacyPolicyContent />
    </div>
  </section>
</Layout>
