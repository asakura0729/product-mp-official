---
interface Props {
  class?: string;
  /** 背景画像を表示するか。既定値は false */
  showBackgroundImage?: boolean;
  /** 背景画像のパス */
  backgroundImage?: string;
  /** 下部ウェーブ SVG の fill 色 */
  waveFill?: string;
}

const { class: className = "", showBackgroundImage = false, backgroundImage = "/images/bg-office.jpg", waveFill = "#fff" } = Astro.props;
---

<header id="page-header" class:list={["page-key-visual relative w-full overflow-hidden bg-gradation-maincolor", className]} aria-labelledby="page-header" data-name="page-header">
  <div class="relative z-10 mx-auto w-full max-w-(--container) px-4 py-12">
    <slot />
  </div>
  {showBackgroundImage && backgroundImage && <img src={backgroundImage} alt="背景画像" class="pointer-events-none absolute inset-0 size-full object-cover" aria-hidden="true" />}
  <svg
    class="pointer-events-none absolute bottom-0 left-0 z-30 block h-10 w-full select-none"
    viewBox="0 0 1280 29"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path fill={waveFill} d="M1280,29V0c-52.4,12.4-319,21.8-640,21.8S52.4,12.4,0,0v29h1280Z" />
  </svg>
</header>
