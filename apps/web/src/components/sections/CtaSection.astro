---
import Fukidashi from "../ui/Fukidashi.astro";
import CtaContact from "../ui/CtaContact.astro";

interface Props {
	/** full: 吹き出し＋問い合わせ / contact-only: 問い合わせブロックのみ */
	variant?: "full" | "contact-only";
}

const { variant = "full" } = Astro.props;

const ctaPrompts = [
	{ lines: ["とりあえず話だけ", "聞いてみたい"] },
	{ lines: ["自分に合う", "サービスかな？"] },
	{ lines: ["○○は対応", "できますか？"] },
];
---

<section
	class="cta-section flex flex-col overflow-hidden"
	aria-labelledby={variant === "full" ? "cta-heading" : "cta-contact-heading"}
>
	{
		variant === "full" ? (
			<div class="cta-section__intro bg-(--main-bg-sub) pb-(--pd-xlarge) pt-6 md:pt-8">
				<div class="relative mx-auto w-[340px] md:w-[600px]">
					<div class="relative flex w-full flex-col items-center md:flex-row md:items-start md:justify-end">
						<div class="cta-section__illust absolute top-[104px] left-4 h-[112px] w-[120px] md:relative md:top-auto md:left-[90px] md:shrink-0">
							<img
								src="/images/illust-woman_think.png"
								alt="イラスト_女性"
								class="pointer-events-none absolute top-[-20px] left-[-100px] h-[auto] w-[200px] max-w-none select-none object-cover md:top-[20px] md:left-[-140px]"
								width="209"
								height="126"
								draggable="false"
							/>
						</div>

						<div class="flex w-full flex-col items-center md:w-[466px] md:items-start">
							<div class="flex h-10 w-full items-center pb-6">
								<h2
									id="cta-heading"
									class="w-full text-center text-xl md:text-2xl font-semibold leading-6 text-(--main-text) md:text-left"
								>
									まずはお気軽にご連絡ください
								</h2>
							</div>

							<ul class="flex w-full flex-col items-end md:w-[480px] md:flex-row md:gap-2">
								{ctaPrompts.map(({ lines }) => (
									<li class="w-[250px] shrink-0 md:w-[150px]">
										<Fukidashi
											tail="bottom-left"
											size="compact"
										>
											{lines.map((line, index) => (
												<>
													{line}
													{index <
														lines.length - 1 && (
														<br class="hidden md:block" />
													)}
												</>
											))}
										</Fukidashi>
									</li>
								))}
							</ul>
						</div>
					</div>
				</div>
			</div>
		) : null
	}

	<!-- 紺色エリア（Figma: gradation-bg） -->
	<div class="cta-section__contact cta-section__contact-bg relative">
		<div
			class="relative mx-auto w-full max-w-[900px] px-4 pb-8 pt-7 md:px-0 md:pt-6"
		>
			<div class="relative">
				<header
					class="w-full pb-2 pt-(--pd-middle) md:pb-(--pd-xlarge)"
				>
					<h3
						id="cta-contact-heading"
						class="w-full text-center font-semibold text-xl leading-8 text-(--white) md:text-2xl md:leading-6"
					>
						ご相談・お問い合わせはこちら
					</h3>
				</header>

				<img
					src="/svg/triangle-down.svg"
					alt=""
					class="pointer-events-none absolute top-[-30px] left-1/2 w-[100px] -translate-x-1/2 md:left-1/2"
					width="80"
					height="21"
				/>

				<CtaContact />

				<img
					src="/images/pic-woman-cta.png"
					alt=""
					class="pointer-events-none absolute top-[45px] right-0 hidden h-[186px] w-[150px] object-cover md:block lg:right-[30px]"
					width="150"
					height="186"
				/>
			</div>
		</div>
	</div>
</section>