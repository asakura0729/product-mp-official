---
import CtaContact from "../ui/CtaContact.astro";
---

<header id="key-visual" class="relative w-full overflow-x-hidden" aria-label="キービジュアル">
  <div class="key-visual__stage relative h-[80vh] w-full overflow-x-hidden md:h-[480px]">
    <canvas id="key-visual-inner" class="cta-section__contact-bg absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

    <div class="key-visual__overlay pointer-events-none absolute inset-0 z-10 mx-auto w-full max-w-(--container) overflow-hidden">
      <img
        src="/images/keyvisual-home-h1.png"
        alt="これまでの常識を一新する Web広告運用の新しい時代へ"
        class="absolute top-6 left-1/2 -translate-x-1/2 w-[80%] md:top-1/2 md:left-0 md:w-[450px] md:-translate-x-0 md:-translate-y-1/2 md:pb-10"
        width="520"
        height="200"
        loading="eager"
      />

      <img
        src="/images/keyvisual-home-zero.png"
        alt=""
        class="hidden absolute right-[14%] bottom-10 w-[150px] object-contain md:bottom-[120px] md:right-[280px] md:block"
        width="200"
        height="280"
        aria-hidden="true"
      />

      <img
        src="/images/keyvisual-woman.png"
        alt="女性"
        class="absolute right-[-50px] bottom-[-50px] w-[280px] h-auto md:w-[360px] md:right-0 md:bottom-[-90px]"
        width="320"
        height="430"
        aria-hidden="true"
      />

      <img
        src="/images/keyvisual-home-baloon_sp.png"
        alt="完全定額！運用手数料ゼロ"
        class="absolute bottom-[200px] right-[180px] z-20 w-[150px] md:bottom-[350px] md:right-[200px]"
        width="150"
        height="80"
        loading="eager"
      />
    </div>
    <svg class="absolute inset-x-0 bottom-0 z-20 block h-10 w-full" viewBox="0 0 1280 21.8" preserveAspectRatio="none" aria-hidden="true">
      <path fill="#ffffff" d="M1280,21.8C1227.6,9.4,961,0,640,0S52.4,9.4,0,21.8h1280Z"></path>
    </svg>
  </div>

  <div class="relative mx-auto w-full max-w-[600px] pt-(--pd-middle) pb-(--pd-large) px-(--pd-middle) md:-mt-[70px] md:pb-10 z-30">
    <CtaContact bordered />
  </div>
</header>

<script type="importmap">
  {
    "imports": {
      "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js"
    }
  }
</script>
<script type="module">
  import * as THREE from "three";

  const GAP = 0;
  const IMG_W = 200;
  const IMG_H = 125;
  const IMAGE_COUNT = 8;
  const SPEED = 0.6;
  const WARP_SUBDIV = 10;
  const BOW = 1;
  const FAN = 1;
  const CURVE_RADIUS = 1;

  const canvas = document.getElementById("key-visual-inner");
  const stage = canvas?.parentElement;

  let viewWidth = window.innerWidth;
  let canvasHeight = stage?.clientHeight ?? 300;
  let stripWidth = 0;
  let offset = 0;
  let imagesReady = false;

  const materials = [];
  const textures = new Array(IMAGE_COUNT);

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(window.devicePixelRatio);
  renderer.setClearColor(0x000000, 0);

  const scene = new THREE.Scene();
  const tileGroup = new THREE.Group();
  scene.add(tileGroup);

  const camera = new THREE.OrthographicCamera(0, 1, 0, 1, 0.1, 1000);
  camera.position.z = 10;

  const basePlane = new THREE.PlaneGeometry(IMG_W, IMG_H, WARP_SUBDIV, WARP_SUBDIV);
  const halfW = IMG_W / 2;
  const halfH = IMG_H / 2;
  const textureLoader = new THREE.TextureLoader();

  function stripWidthFor(count) {
    return count * (IMG_W + GAP);
  }

  function rowTopY() {
    return (canvasHeight - IMG_H) / 2;
  }

  function cylinderRadius() {
    return viewWidth * CURVE_RADIUS;
  }

  /** 平面座標を円筒（パノラマ）投影へマッピング */
  function mapPoint(x, y) {
    const cx = viewWidth / 2;
    const r = cylinderRadius();
    const angle = (x - cx) / r;
    const sx = cx + r * Math.sin(angle);
    const bow = r * (1 - Math.cos(angle)) * BOW;
    const nx = (x - cx) / cx;
    const fan = nx * nx * (y - canvasHeight) * FAN;
    return [sx, y + bow + fan];
  }

  function syncSize() {
    if (!stage) return;
    viewWidth = window.innerWidth;
    canvasHeight = stage.clientHeight;
    stripWidth = stripWidthFor(IMAGE_COUNT);
    renderer.setSize(viewWidth, canvasHeight, false);
    camera.left = 0;
    camera.right = viewWidth;
    camera.top = 0;
    camera.bottom = canvasHeight;
    camera.updateProjectionMatrix();
  }

  function configureTexture(texture) {
    texture.colorSpace = THREE.SRGBColorSpace;
    texture.wrapS = THREE.ClampToEdgeWrapping;
    texture.wrapT = THREE.ClampToEdgeWrapping;
    texture.minFilter = THREE.LinearFilter;
    texture.magFilter = THREE.LinearFilter;
  }

  let loadedCount = 0;
  for (let i = 1; i <= IMAGE_COUNT; i++) {
    const id = String(i).padStart(2, "0");
    const index = i - 1;
    textureLoader.load(
      `images/top-slide/slide-${id}.png`,
      (texture) => {
        configureTexture(texture);
        textures[index] = texture;
        materials[index] = new THREE.MeshBasicMaterial({
          map: texture,
          side: THREE.DoubleSide,
        });
        loadedCount++;
        if (loadedCount === IMAGE_COUNT) {
          imagesReady = true;
        }
      },
      undefined,
      () => console.error(`Failed to load image/slide-${id}.png`),
    );
  }

  function createWarpedGeometry(baseX, baseY) {
    const geometry = basePlane.clone();
    const positions = geometry.attributes.position;
    for (let i = 0; i < positions.count; i++) {
      const lx = positions.getX(i);
      const ly = positions.getY(i);
      const logicalX = baseX + lx + halfW;
      const logicalY = baseY + halfH - ly;
      const mapped = mapPoint(logicalX, logicalY);
      positions.setXYZ(i, mapped[0], mapped[1], 0);
    }
    positions.needsUpdate = true;
    geometry.computeVertexNormals();
    return geometry;
  }

  function clearTiles() {
    while (tileGroup.children.length > 0) {
      const mesh = tileGroup.children[0];
      tileGroup.remove(mesh);
      mesh.geometry.dispose();
    }
  }

  function buildTiles() {
    clearTiles();
    const baseY = rowTopY();

    let originX = -((offset % stripWidth) + stripWidth) % stripWidth;
    while (originX < viewWidth + stripWidth) {
      for (let i = 0; i < IMAGE_COUNT; i++) {
        const x = originX + i * (IMG_W + GAP);
        const right = x + IMG_W;
        if (right < -IMG_W || x > viewWidth + IMG_W) {
          continue;
        }

        const material = materials[i];
        if (!material) continue;

        const geometry = createWarpedGeometry(x, baseY);
        tileGroup.add(new THREE.Mesh(geometry, material));
      }
      originX += stripWidth;
    }
  }

  syncSize();
  window.addEventListener("resize", syncSize);

  function frame() {
    if (imagesReady && loadedCount === IMAGE_COUNT) {
      buildTiles();
      offset = (offset + SPEED) % stripWidth;
    }
    renderer.render(scene, camera);
    requestAnimationFrame(frame);
  }

  frame();
</script>
