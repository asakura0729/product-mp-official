---
import CtaContact from "../ui/CtaContact.astro";
import { SITE_NAME } from "../../data/navigation";

const keyVisualAlt = `「${SITE_NAME}」これまでの常識を一新するWeb広告運用の新しい時代へ`;
---

<header id="key-visual" class="relative w-full overflow-x-hidden" aria-label="キービジュアル">
  <div id="key-visual-inner" class="key-visual__stage relative h-[580px] w-full overflow-x-hidden md:h-[480px] bg-(--main-bg) z-10">
    <canvas id="key-visual-canvas" class="bg-gradation-maincolor absolute inset-0 h-full w-full z-10" aria-hidden="true"></canvas>

    <div class="pointer-events-none absolute inset-0 z-20 mx-auto w-full max-w-(--container) overflow-hidden">
      <!--見出し -->
      <h1 class="absolute top-6 left-1/2 -translate-x-1/2 z-40 w-[340px] md:left-5 md:flex md:w-[400px] md:translate-x-0 md:items-center md:top-12 md:pb-10 lg:left-0 lg:w-[450px]">
        <img src="/images/keyvisual-home-h1.png" alt={keyVisualAlt} class="h-auto w-full crisp-edges" width="520" height="200" loading="eager" />
      </h1>

      <!--図形：ゼロ -->
      <svg
        class="absolute right-[100px] bottom-[20px] w-[150px] opacity-70 md:w-[200px] md:bottom-[110px] md:right-[240px] md:block z-20"
        viewBox="0 0 600 600"
        width="200"
        height="280"
        fill="none"
        aria-hidden="true"
      >
        <path fill="#ffffff" fill-rule="evenodd" d="M300 30a177 270 0 1 1 0 540a177 270 0 1 1 0-540M300 106a86 194 0 1 0 0 388a86 194 0 1 0 0-388"></path>
      </svg>

      <!--写真：女性 -->
      <img
        src="/images/keyvisual-woman.png?v=20260702213220"
        alt="女性"
        class="absolute right-[-50px] bottom-[-50px] w-[240px] z-30 h-auto md:right-0 md:bottom-[-90px] md:w-[360px]"
        width="320"
        height="430"
        aria-hidden="true"
      />

      <!--フキダシ：完全定額！運用手数料ゼロ -->
      <img
        src="/images/keyvisual-home-baloon_sp.png"
        alt="完全定額！運用手数料ゼロ"
        class="absolute w-[120px] bottom-[225px] right-[100px] z-50 md:w-[160px] md:bottom-[350px] md:right-[200px]"
        width="150"
        height="80"
        loading="eager"
      />
    </div>

    <div id="key-visual-loading" class="absolute inset-0 z-[60] h-full w-full bg-(--main-bg) transition-opacity duration-500">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-10 w-10 animate-spin rounded-full border-4 border-white/30 border-t-white" role="status" aria-label="Loading"></div>
    </div>

    <svg class="absolute inset-x-0 bottom-[-1px] block h-[20px] w-full z-40" viewBox="0 0 1280 21.8" preserveAspectRatio="none" aria-hidden="true">
      <path fill="#ffffff" d="M1280,21.8C1227.6,9.4,961,0,640,0S52.4,9.4,0,21.8h1280Z"></path>
    </svg>
  </div>

  <div class="relative mx-auto w-full max-w-[600px] pt-(--pd-middle) pb-(--pd-large) px-(--pd-middle) md:-mt-[70px] md:pb-10 z-20">
    <CtaContact bordered />
  </div>
</header>

<script type="importmap">
  {
    "imports": {
      "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js"
    }
  }
</script>
<script type="module">
  import * as THREE from "three";

  const MD_BREAKPOINT = 768;

  const DESKTOP_CONFIG = {
    GAP: 0,
    IMG_W: 200,
    IMG_H: 125,
    IMAGE_COUNT: 8,
    SPEED: 0.6,
    WARP_SUBDIV: 10,
    BOW: 1,
    FAN: 1,
    CURVE_RADIUS: 1,
  };

  const MOBILE_CONFIG = {
    GAP: 0,
    IMG_W: 200,
    IMG_H: 150,
    IMAGE_COUNT: 8,
    SPEED: 0.6,
    WARP_SUBDIV: 4,
    BOW: 3,
    FAN: 0.5,
    CURVE_RADIUS: 2,
  };

  function isMobileViewport() {
    return window.innerWidth < MD_BREAKPOINT;
  }

  function getConfigForViewport() {
    return isMobileViewport() ? MOBILE_CONFIG : DESKTOP_CONFIG;
  }

  const canvas = document.getElementById("key-visual-canvas");
  const stage = canvas?.parentElement;
  const loadingEl = document.getElementById("key-visual-loading");
  let domImagesReady = false;
  let loadingHideScheduled = false;

  function tryHideLoading() {
    if (!domImagesReady || !imagesReady || !loadingEl || loadingHideScheduled) return;
    loadingHideScheduled = true;

    setTimeout(() => {
      const hide = () => loadingEl.classList.add("hidden");

      loadingEl.classList.add("opacity-0");
      loadingEl.addEventListener(
        "transitionend",
        (event) => {
          if (event.propertyName === "opacity") hide();
        },
        { once: true },
      );
      setTimeout(hide, 600);
    }, 500);
  }

  function waitForDomImages(container) {
    const imgs = container.querySelectorAll("img");
    return Promise.all(
      Array.from(imgs).map(
        (img) =>
          new Promise((resolve) => {
            if (img.complete && img.naturalHeight !== 0) {
              resolve();
              return;
            }
            img.addEventListener("load", resolve, { once: true });
            img.addEventListener("error", resolve, { once: true });
          }),
      ),
    );
  }

  if (stage) {
    waitForDomImages(stage).then(() => {
      domImagesReady = true;
      tryHideLoading();
    });
  }

  let config = getConfigForViewport();
  let isMobile = isMobileViewport();
  let viewWidth = window.innerWidth;
  let canvasHeight = stage?.clientHeight ?? 300;
  let stripWidth = 0;
  let offset = 0;
  let imagesReady = false;

  const materials = [];
  const textures = new Array(DESKTOP_CONFIG.IMAGE_COUNT);

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(window.devicePixelRatio);
  renderer.setClearColor(0x000000, 0);

  const scene = new THREE.Scene();
  const tileGroup = new THREE.Group();
  scene.add(tileGroup);

  const camera = new THREE.OrthographicCamera(0, 1, 0, 1, 0.1, 1000);
  camera.position.z = 10;

  function createBasePlane(cfg) {
    return new THREE.PlaneGeometry(cfg.IMG_W, cfg.IMG_H, cfg.WARP_SUBDIV, cfg.WARP_SUBDIV);
  }

  let basePlane = createBasePlane(config);
  let halfW = config.IMG_W / 2;
  let halfH = config.IMG_H / 2;
  const textureLoader = new THREE.TextureLoader();

  function stripWidthFor(count) {
    return count * (config.IMG_W + config.GAP);
  }

  function rowTopY() {
    if (isMobile) {
      return canvasHeight - config.IMG_H - 70;
    }
    return (canvasHeight - config.IMG_H) / 2;
  }

  function cylinderRadius() {
    return viewWidth * config.CURVE_RADIUS;
  }

  /** 平面座標を円筒（パノラマ）投影へマッピング */
  function mapPoint(x, y) {
    const cx = viewWidth / 2;
    const r = cylinderRadius();
    const angle = (x - cx) / r;
    const sx = cx + r * Math.sin(angle);
    const bow = r * (1 - Math.cos(angle)) * config.BOW;
    const nx = (x - cx) / cx;
    const fan = nx * nx * (y - canvasHeight) * config.FAN;
    return [sx, y + bow + fan];
  }

  function applyConfig(nextConfig) {
    config = nextConfig;
    basePlane.dispose();
    basePlane = createBasePlane(config);
    halfW = config.IMG_W / 2;
    halfH = config.IMG_H / 2;
    stripWidth = stripWidthFor(config.IMAGE_COUNT);
    offset = 0;
    clearTiles();
  }

  function syncSize() {
    if (!stage) return;

    const nextIsMobile = isMobileViewport();
    if (nextIsMobile !== isMobile) {
      isMobile = nextIsMobile;
      applyConfig(getConfigForViewport());
    }

    viewWidth = window.innerWidth;
    canvasHeight = stage.clientHeight;
    stripWidth = stripWidthFor(config.IMAGE_COUNT);
    renderer.setSize(viewWidth, canvasHeight, false);
    camera.left = 0;
    camera.right = viewWidth;
    camera.top = 0;
    camera.bottom = canvasHeight;
    camera.updateProjectionMatrix();
  }

  function configureTexture(texture) {
    texture.colorSpace = THREE.SRGBColorSpace;
    texture.wrapS = THREE.ClampToEdgeWrapping;
    texture.wrapT = THREE.ClampToEdgeWrapping;
    texture.minFilter = THREE.LinearFilter;
    texture.magFilter = THREE.LinearFilter;
  }

  let loadedCount = 0;
  function markTextureLoaded() {
    loadedCount++;
    if (loadedCount === DESKTOP_CONFIG.IMAGE_COUNT) {
      imagesReady = true;
      tryHideLoading();
    }
  }

  for (let i = 1; i <= DESKTOP_CONFIG.IMAGE_COUNT; i++) {
    const id = String(i).padStart(2, "0");
    const index = i - 1;
    textureLoader.load(
      `images/top-slide/slide-${id}.png`,
      (texture) => {
        configureTexture(texture);
        textures[index] = texture;
        materials[index] = new THREE.MeshBasicMaterial({
          map: texture,
          side: THREE.DoubleSide,
        });
        markTextureLoaded();
      },
      undefined,
      () => {
        console.error(`Failed to load image/slide-${id}.png`);
        markTextureLoaded();
      },
    );
  }

  function createWarpedGeometry(baseX, baseY) {
    const geometry = basePlane.clone();
    const positions = geometry.attributes.position;
    for (let i = 0; i < positions.count; i++) {
      const lx = positions.getX(i);
      const ly = positions.getY(i);
      const logicalX = baseX + lx + halfW;
      const logicalY = baseY + halfH - ly;
      const mapped = mapPoint(logicalX, logicalY);
      positions.setXYZ(i, mapped[0], mapped[1], 0);
    }
    positions.needsUpdate = true;
    geometry.computeVertexNormals();
    return geometry;
  }

  function clearTiles() {
    while (tileGroup.children.length > 0) {
      const mesh = tileGroup.children[0];
      tileGroup.remove(mesh);
      mesh.geometry.dispose();
    }
  }

  function buildTiles() {
    clearTiles();
    const baseY = rowTopY();

    let originX = -((offset % stripWidth) + stripWidth) % stripWidth;
    while (originX < viewWidth + stripWidth) {
      for (let i = 0; i < config.IMAGE_COUNT; i++) {
        const x = originX + i * (config.IMG_W + config.GAP);
        const right = x + config.IMG_W;
        if (right < -config.IMG_W || x > viewWidth + config.IMG_W) {
          continue;
        }

        const material = materials[i];
        if (!material) continue;

        const geometry = createWarpedGeometry(x, baseY);
        tileGroup.add(new THREE.Mesh(geometry, material));
      }
      originX += stripWidth;
    }
  }

  syncSize();
  window.addEventListener("resize", syncSize);

  function frame() {
    if (imagesReady && loadedCount === DESKTOP_CONFIG.IMAGE_COUNT) {
      buildTiles();
      offset = (offset + config.SPEED) % stripWidth;
    }
    renderer.render(scene, camera);
    requestAnimationFrame(frame);
  }

  frame();
</script>
