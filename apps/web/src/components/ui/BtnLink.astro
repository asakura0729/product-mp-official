---
import IconCircleChevronRight from './IconCircleChevronRight.astro';

interface Props {
	href: string;
	class?: string;
}

const { href, class: className = '' } = Astro.props;
---

<a
	href={href}
	class:list={[
		'btn-link relative flex min-w-[320px] items-center justify-center gap-2.5 rounded-[24px] border border-(--border-link) bg-(--white) py-2 shadow-[0_2px_1px_rgba(0,0,0,0.25)] transition-opacity hover:opacity-90',
		className,
	]}
	data-name="btn-link"
>
	<IconCircleChevronRight class="absolute top-1/2 left-[11px] size-[25px] -translate-y-1/2" />
	<span class="btn-link__label px-8 text-center text-[16px] leading-(--line-height-default) font-medium break-words text-(--base-text)">
		<slot>詳細はこちら</slot>
	</span>
</a>
