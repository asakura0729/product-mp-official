---
interface Props {
	/** セクション見出しの id（aria-labelledby 等に使用） */
	id?: string;
	class?: string;
}

const { id, class: className = '' } = Astro.props;

const readClasses =
	'font-normal md:text-lg leading-6';

const titleClasses =
	'font-bold text-2xl leading-9 md:text-3xl md:leading-10';
---

<div
	class:list={[
		'header-h2 flex w-full flex-col items-center justify-center gap-1 break-words pb-6 text-center text-(--base-text)',
		className,
	]}
	data-name="header-h2"
>
	{
		Astro.slots.has('lead') && (
			<p class:list={['header-h2__lead', readClasses]}>
				<slot name="lead" />
			</p>
		)
	}

	<h2 id={id} class:list={['header-h2__title', titleClasses]}>
		<slot />
	</h2>

	{
		Astro.slots.has('summary') && (
			<p class:list={['header-h2__summary', readClasses]}>
				<slot name="summary" />
			</p>
		)
	}
</div>
