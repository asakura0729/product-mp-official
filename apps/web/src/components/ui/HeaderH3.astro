---
interface Props {
	/** 見出しの id（aria-labelledby 等に使用） */
	id?: string;
	/** center: Figmaコンポーネント既定 / left: セクション内左寄せ */
	align?: 'center' | 'left';
	class?: string;
}

const { id, class: className = '', align = 'center' } = Astro.props;

const titleClasses =
	'header-h3__title min-w-0 flex-1 break-words font-bold text-[20px] leading-8 text-(--base-text) md:text-(length:--font-size-h3) md:leading-(length:--line-height-h3)';
---

<div
	class:list={[
		'header-h3 flex w-full pb-(--pd-middle)',
		align === 'center' ? 'items-center justify-center' : 'items-start',
		className,
	]}
	data-name="header-h3"
>
	<h3
		id={id}
		class:list={[titleClasses, align === 'center' ? 'text-center' : 'text-left']}
	>
		<slot />
	</h3>
</div>
