---
interface Props {
	image: string;
	imageAlt?: string;
	/** title スロット未指定時に表示 */
	title?: string;
	class?: string;
}

const { image, imageAlt = '', title, class: className = '' } = Astro.props;
---

<div class:list={['card-pic-left flex w-full items-center justify-center', className]} data-name="card-pic_left">
	<div class="flex w-full items-center gap-4 rounded-(--border-radius) border border-(--border) bg-(--white) px-[15px] py-2.5">
		<div class="size-11 shrink-0">
			<img
				src={image}
				alt={imageAlt}
				class="size-full object-contain"
				width="45"
				height="45"
				loading="lazy"
			/>
		</div>

		<div class="min-w-0 flex-1">
			<p class="text-base leading-[27px] font-bold text-(--base-text)">
				<slot name="title">{title}</slot>
			</p>
			<div class="text-sm leading-[22px] text-(--base-text)">
				<slot />
			</div>
		</div>
	</div>
</div>
