---
interface Props {
	question: string;
	answer: string;
	class?: string;
}

const { question, answer, class: className = '' } = Astro.props;
---

<div
	class:list={[
		'card-faq flex w-full flex-col overflow-hidden rounded-(--border-radius) border border-(--border) bg-(--white)',
		className,
	]}
	data-name="card-faq"
>
	<div class="flex w-full items-start gap-2.5 bg-(--main-bg) p-4">
		<div class="flex w-[30px] shrink-0 flex-col py-2">
			<div class="flex w-full items-start rounded-(--border-radius) bg-(--white)">
				<p class="w-[30px] text-center text-base leading-6 font-medium text-(--main-bg)">Q</p>
			</div>
		</div>
		<p class="min-w-0 flex-1 whitespace-pre-line text-base leading-[27px] text-(--white)">{question}</p>
	</div>

	<div class="flex w-full items-start gap-2.5 px-4 pt-2 pb-4">
		<div class="flex w-[30px] shrink-0 flex-col py-1">
			<div class="flex w-full items-center justify-center rounded-(--border-radius) bg-(--base-bg-lblue)">
				<p class="w-[30px] text-center text-base leading-6 font-medium text-(--main-text)">A</p>
			</div>
		</div>
		<p class="min-w-0 flex-1 text-sm leading-[27px] text-(--base-text)">{answer}</p>
	</div>
</div>
