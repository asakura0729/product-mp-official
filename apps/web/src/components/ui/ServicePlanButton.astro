---
import { servicePlans, type ServicePlanVariant } from '../../data/service-plans';

interface Props {
	variant: ServicePlanVariant;
	class?: string;
}

const { variant, class: className = '' } = Astro.props;
const plan = servicePlans[variant];
---

<a
	href={plan.href}
	class:list={[
		'service-plan-button group relative flex w-full max-w-[450px] flex-col items-center overflow-hidden rounded-(--border-radius) border-[3px] bg-(--white) pb-12 shadow-[0_4px_4px_rgba(0,0,0,0.25)] transition-opacity hover:opacity-90 md:h-full md:min-h-[530px] md:w-[420px] md:max-w-none',
		plan.borderColorClass,
		plan.cardHeightClass,
		className,
	]}
	data-name={plan.dataName}
	aria-label={`${plan.title}の詳細ページへ`}
>
	<div class:list={['flex w-full shrink-0 items-center justify-center pt-2 pb-2.5', plan.headerBgClass]}>
		<p class="text-center text-xl font-bold tracking-widest text-(--white)">{plan.title}</p>
	</div>

	<div class="relative h-[112px] w-full shrink-0 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 h-[120px] w-[450px] -translate-x-1/2 -translate-y-1/2">
			<img
				src={plan.imageSrc}
				alt={plan.imageAlt}
				class="pointer-events-none size-full max-w-none object-cover"
				width="450"
				height="120"
				loading="lazy"
			/>
		</div>
	</div>

	<div class="flex w-full shrink-0 items-center justify-center pt-3 pb-2">
		<p class="break-words px-4 text-center text-sm leading-6 text-(--base-text)">
			{plan.catchLines.map((line, index) => (
				<>
					{line}
					{index < plan.catchLines.length - 1 && <br />}
				</>
			))}
		</p>
	</div>

	<div class="flex w-full shrink-0 flex-col items-end py-2 pr-4 text-right text-(--base-text) md:w-[380px] md:pr-0">
		<p class="text-[20px] leading-5 font-bold">
			月額{' '}
			<span class="font-famly-din text-[40px] leading-5 text-(--accent-strong)">
				{plan.price}
			</span>{' '}
			万円 ~
		</p>
		<p class="w-full text-[12px] leading-6">{plan.priceNote}</p>
	</div>

	<div class="w-full shrink-0 border-b border-(--border-link) bg-(--base-bg-lgray) px-6 py-4 md:min-h-0 md:flex-1">
		{
			plan.featureGroups.map((group, groupIndex) => (
				<p class:list={['text-sm leading-6 text-(--base-text)', groupIndex > 0 && 'mt-0']}>
					{group.map((item) => (
						<>
							<span class:list={['leading-6', plan.bulletColorClass]}>●</span>
							<span class="leading-6"> {item.text}</span>
							{item.breakAfter && <br />}
						</>
					))}
				</p>
			))
		}
	</div>

	<div class="absolute bottom-[0.25rem] md:bottom-[-1.4px] left-1/2 flex -translate-x-1/2 items-start gap-[23px] pr-8 pb-3">
		<svg
			class:list={['size-[25px] shrink-0', plan.iconColorClass]}
			width="25"
			height="25"
			viewBox="0 0 25 25"
			fill="none"
			aria-hidden="true"
		>
			<path
				d="M2.5 12.5C2.5 18.0234 6.97656 22.5 12.5 22.5C18.0234 22.5 22.5 18.0234 22.5 12.5C22.5 6.97656 18.0234 2.5 12.5 2.5C6.97656 2.5 2.5 6.97656 2.5 12.5ZM11.9141 17.2266C11.5469 17.5938 10.9531 17.5938 10.5898 17.2266C10.2266 16.8594 10.2227 16.2656 10.5898 15.9023L13.9883 12.5039L10.5898 9.10547C10.2227 8.73828 10.2227 8.14453 10.5898 7.78125C10.957 7.41797 11.5508 7.41406 11.9141 7.78125L15.9766 11.8359C16.3438 12.2031 16.3438 12.7969 15.9766 13.1602L11.9141 17.2266Z"
				fill="currentColor"></path>
		</svg>
		<p class="text-center text-[16px] leading-6 font-bold whitespace-nowrap text-(--base-text)">
			詳細はこちら
		</p>
	</div>
</a>
