---
interface Props {
	/** ステップ番号 */
	step: number | string;
	/** 見出し */
	title: string;
	/** イラスト画像パス */
	image?: string;
	imageAlt?: string;
	showImage?: boolean;
	class?: string;
}

const {
	step,
	title,
	image = '',
	imageAlt = '',
	showImage = true,
	class: className = '',
} = Astro.props;
---

<div
	class:list={[
		'card-ol flex w-full flex-col items-center overflow-hidden rounded-(--border-radius) border border-(--border) bg-(--white) pb-4',
		className,
	]}
	data-name="card-ol"
>
	<div class="flex min-h-[75px] w-full items-center gap-2.5 bg-(--main-bg) px-4 py-2">
		<p
			class="font-family-din w-[50px] shrink-0 text-center text-[60px] leading-8 text-white/25"
			aria-hidden="true"
		>
			{step}
		</p>
		<p class="min-w-0 flex-1 whitespace-pre-line text-(--white)">{title}</p>
	</div>

	<div class="w-full px-3 py-3">
		<div class="text-sm leading-6">
			<slot />
		</div>
	</div>

	{
		showImage && image && (
			<div class="flex h-[120px] items-center justify-center">
				<img
					src={image}
					alt={imageAlt}
					class="size-full object-contain"
					width="100%"
					height="auto"
					loading="lazy"
				/>
			</div>
		)
	}
</div>
