---
import { EMAIL_CONTACT_PATH, PHONE_HOURS, PHONE_NUMBER } from '../../data/navigation';
---

<div
	class="contact-modal fixed inset-0 z-[70] flex items-center justify-center p-4"
	x-show="$store.layout.contactModalOpen"
	x-cloak
	@keydown.escape.window="$store.layout.closeContactModal()"
>
	<div
		class="contact-modal__overlay absolute inset-0 bg-black/50"
		@click="$store.layout.closeContactModal()"
		x-show="$store.layout.contactModalOpen"
		x-transition.opacity
	></div>

	<div
		class="contact-modal__dialog relative w-full max-w-md rounded-xl bg-white p-6 shadow-xl"
		role="dialog"
		aria-modal="true"
		aria-labelledby="contact-modal-title"
		x-show="$store.layout.contactModalOpen"
		x-transition
	>
		<button
			type="button"
			class="absolute right-4 top-4"
			@click="$store.layout.closeContactModal()"
			aria-label="閉じる"
		>
			<img src="/svg/btn-close.svg" alt="" class="size-8" width="32" height="32" />
		</button>

		<h2 id="contact-modal-title" class="mb-4 pr-8 text-lg font-bold text-[#2b5696]">
			お問い合わせ
		</h2>

		<p class="mb-6 text-sm leading-relaxed text-[#444]">
			お電話またはメールにてお気軽にご相談ください。専門スタッフが対応いたします。
		</p>

		<div class="space-y-4">
			<div class="rounded-lg border border-[#ddd] bg-[#fafafa] p-4 text-center">
				<p class="mb-2 text-sm font-semibold text-[#222]">お電話でのお問い合わせ</p>
				<a href={`tel:${PHONE_NUMBER.replace(/-/g, '')}`} class="inline-flex items-center gap-2 font-famly-din text-3xl text-(--cta_tel)">
					<img src="/svg/icon-tel.svg" alt="" class="size-7" width="28" height="28" />
					{PHONE_NUMBER}
				</a>
				<p class="mt-2 text-xs text-[#666]">{PHONE_HOURS}</p>
			</div>

			<a
				href={EMAIL_CONTACT_PATH}
				class="flex items-center justify-center gap-2 rounded-lg border-2 border-(--cta_tel) px-4 py-3 text-sm font-semibold text-[#222] transition-opacity hover:opacity-90"
			>
				<img src="/images/shukyaku/img-vector.png" alt="" class="size-6" width="24" height="24" />
				メールでのお問い合わせはこちら
			</a>
		</div>
	</div>
</div>
