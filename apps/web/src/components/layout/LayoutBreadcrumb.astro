---
import IconHome from '../ui/IconHome.astro';

export type BreadcrumbItem = {
	/** JSON-LD・アクセシビリティ用のラベル */
	label: string;
	href?: string;
	/** 表示をアイコンに差し替える */
	icon?: 'home';
};

interface Props {
	items: BreadcrumbItem[];
	class?: string;
}

const { items, class: className = "" } = Astro.props;

const siteOrigin = Astro.url.origin;

function resolveItemUrl(href: string | undefined): string {
	if (href) {
		return new URL(href, siteOrigin).href;
	}
	return new URL(Astro.url.pathname, siteOrigin).href;
}

const breadcrumbJsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: items.map((item, index) => ({
		"@type": "ListItem",
		position: index + 1,
		item: {
			"@id": resolveItemUrl(item.href),
			name: item.label,
		},
	})),
};
---

<nav
	id="site-breadcrumb"
	class:list={[
		'layout-breadcrumb absolute w-full max-w-7xl top-(--header-height-sp) md:top-(--header-height-pc) left-1/2 -translate-x-1/2 flex items-center px-4 md:px-8 py-3 text-xs md:text-sm text-(--white) z-10',
		className,
	]}
	aria-label="パンくずリスト"
	data-name="layout-breadcrumb"
>
	<ol class="flex flex-wrap items-center">
		{
			items.map((item, index) => (
				<li class="inline-flex items-center">
					{index > 0 && (
						<span class="px-2" aria-hidden="true">
							＞
						</span>
					)}
					{item.href ? (
						<a
							href={item.href}
							class="inline-flex items-center transition-opacity hover:opacity-80"
							aria-label={item.icon ? item.label : undefined}
						>
							{item.icon === 'home' ? (
								<IconHome class="size-5 shrink-0 text-[#fff]" />
							) : (
								item.label
							)}
						</a>
					) : (
						<span aria-current="page">{item.label}</span>
					)}
				</li>
			))
		}
	</ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
