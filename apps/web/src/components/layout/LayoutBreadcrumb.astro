---
export type BreadcrumbItem = {
	label: string;
	href?: string;
};

interface Props {
	items: BreadcrumbItem[];
	class?: string;
}

const { items, class: className = "" } = Astro.props;
---

<nav
	id="site-breadcrumb"
	class:list={[
		'layout-breadcrumb absolute w-full max-w-7xl top-(--header-height) left-1/2 -translate-x-1/2 flex items-center px-4 md:px-8 py-3 text-xs md:text-sm text-(--white) z-10',
		className,
	]}
	aria-label="パンくずリスト"
	data-name="layout-breadcrumb"
>
	<ol class="flex flex-wrap items-center">
		{
			items.map((item, index) => (
				<li class="inline-flex items-center">
					{index > 0 && (
						<span class="px-2" aria-hidden="true">
							＞
						</span>
					)}
					{item.href ? (
						<a
							href={item.href}
							class="transition-opacity hover:opacity-80"
						>
							{item.label}
						</a>
					) : (
						<span aria-current="page">{item.label}</span>
					)}
				</li>
			))
		}
	</ol>
</nav>
