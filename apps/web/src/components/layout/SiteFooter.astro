---
import SiteLogo from './SiteLogo.astro';
import { footerNavItems } from '../../data/navigation';
---

<footer class="site-footer bg-(--base-bg-lgray) px-4 pt-8 pb-[100px] lg:px-8 border-(--border) border-t">
	<div class="site-footer__inner mx-auto max-w-7xl">
		<!-- SP / TAB -->
		<div class="flex flex-col gap-4 lg:hidden">
			<SiteLogo />
			<nav aria-label="フッターナビゲーション">
				<ul class="flex flex-wrap gap-x-1 gap-y-1 text-xs leading-6">
					{
						footerNavItems.map((item, index) => (
							<li class="flex items-center">
								<a
									href={item.href}
									class="hover:text-(--main-text) hover:underline"
									{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
								>
									{item.label}
								</a>
								<span class="mx-1 text-[#999]" aria-hidden="true">｜</span>
							</li>
						))
					}
				</ul>
			</nav>
			<p class="text-xs">Copyright© LAB.U, Inc. All Rights Reserved.</p>
		</div>

		<!-- PC: 左ロゴ / 右リンク＋コピーライト -->
		<div class="hidden items-start justify-between gap-8 lg:flex">
			<SiteLogo class="shrink-0" />

			<div class="flex flex-col items-end gap-2">
				<nav aria-label="フッターナビゲーション">
					<ul class="flex flex-wrap justify-end gap-x-1 gap-y-1 text-sm leading-6">
						{
							footerNavItems.map((item, index) => (
								<li class="flex items-center">
									{index > 0 && <span class="mx-1 text-[#999]" aria-hidden="true">｜</span>}
									<a
										href={item.href}
										class="hover:text-(--main-text) hover:underline"
										{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
									>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
				<p class="text-xs">Copyright© LAB.U, Inc. All Rights Reserved.</p>
			</div>
		</div>
	</div>
</footer>
