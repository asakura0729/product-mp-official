---
import SiteLogo from './SiteLogo.astro';
import { headerNavItems } from '../../data/navigation';

const inquiryPath = '/contact';
---

<header id="site_header" class="site-header sticky top-0 z-(--z-index-header) border-b border-[#ddd] bg-white z-[100]">
	<div class="site-header__inner mx-auto flex h-(--header-height) max-w-7xl items-center justify-between px-4 lg:px-8">
		<SiteLogo />

		<!-- PC ナビ -->
		<nav class="site-header__nav hidden h-full items-center gap-6 self-stretch lg:flex" aria-label="メインナビゲーション">
			<ul class="flex items-center gap-5">
				{
					headerNavItems.map((item) => (
						<li>
							<a
								href={item.href}
								class="text-sm transition-colors hover:text-(--main-text)"
								{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
							>
								{item.label}
								{item.external && (
									<img src="/svg/icon-window_new.svg" alt="" class="ml-0.5 inline size-3.5 opacity-60" width="14" height="14" />
								)}
							</a>
						</li>
					))
				}
			</ul>
			<a
				href={inquiryPath}
				class="site-header__cta inline-flex h-full shrink-0 items-center px-5 text-sm font-bold text-white bg-(--cta_tel) transition-opacity hover:opacity-90"
			>
				お問い合わせ
			</a>
		</nav>

		<!-- TAB / SP ハンバーガー -->
		<button
			id="site_header-menu_btn"
			type="button"
			class="site-header__menu-btn relative size-11 shrink-0 lg:hidden"
			@click="$store.layout.menuOpen ? $store.layout.closeMenu() : $store.layout.openMenu()"
			:aria-label="$store.layout.menuOpen ? 'メニューを閉じる' : 'メニューを開く'"
			:aria-expanded="$store.layout.menuOpen"
		>
			<img
				src="/svg/btn-togglemenu.svg"
				alt=""
				class="size-full"
				width="45"
				height="45"
				x-show="!$store.layout.menuOpen"
			/>
			<img
				src="/svg/btn-close.svg"
				alt=""
				class="size-full"
				width="45"
				height="45"
				x-show="$store.layout.menuOpen"
			/>
		</button>
	</div>
</header>
