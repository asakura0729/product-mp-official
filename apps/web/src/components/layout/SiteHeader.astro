---
import SiteLogo from './SiteLogo.astro';
import { headerNavItems, ROUTES } from '../../data/navigation';
import { isSamePath } from '../../data/routes';

const inquiryPath = ROUTES.contact;
const currentPath = Astro.url.pathname;
---

<header id="site_header" class="site-header sticky top-0 z-(--z-index-header) border-b border-[#ddd] bg-white z-[100]">
	<div class="site-header__inner mx-auto flex h-(--header-height-sp) md:h-(--header-height-pc) max-w-7xl items-center justify-between px-4 lg:px-8">
		<SiteLogo />

		<!-- PC ナビ -->
		<nav class="site-header__nav hidden h-full items-center gap-6 self-stretch lg:flex" aria-label="メインナビゲーション">
			<ul class="flex items-center gap-2 h-full pb-[2px] pr-2">
				{
					headerNavItems.map((item) => {
						const isActive = !item.external && isSamePath(currentPath, item.href);
						return (
						<li class="h-full">
							<a
								href={item.href}
								class:list={[
									'inline-flex h-full items-center text-sm transition-colors hover:text-(--main-text) px-2',
									{ 'bg-(--main-bg-sub)': isActive },
								]}
								aria-current={isActive ? 'page' : undefined}
								{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
							>
								{item.label}
								{item.external && (
									<img src="/svg/icon-window_new.svg" alt="" class="ml-2 inline size-3.5 opacity-60" width="14" height="14" />
								)}
							</a>
						</li>
						);
					})
				}
			</ul>
			<a
				href={inquiryPath}
				class="site-header__cta inline-flex text-sm h-full shrink-0 items-center px-5 font-bold text-white bg-(--cta_tel) transition-opacity hover:opacity-90"
			>
				お問い合わせ
			</a>
		</nav>

		<!-- TAB / SP ハンバーガー -->
		<button
			id="site_header-menu_btn"
			type="button"
			class="site-header__menu-btn relative size-12 h-full shrink-0 lg:hidden"
			@click="$store.layout.menuOpen ? $store.layout.closeMenu() : $store.layout.openMenu()"
			:aria-label="$store.layout.menuOpen ? 'メニューを閉じる' : 'メニューを開く'"
			:aria-expanded="$store.layout.menuOpen"
		>
			<img
				src="/svg/btn-togglemenu.svg"
				alt=""
				class="size-full"
				width="45"
				height="45"
				x-show="!$store.layout.menuOpen"
			/>
			<img
				src="/svg/btn-close.svg"
				alt=""
				class="size-full"
				width="45"
				height="45"
				x-show="$store.layout.menuOpen"
			/>
		</button>
	</div>
</header>
