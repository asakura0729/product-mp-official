---
import "../styles/global.css";
import SiteHeader from "../components/layout/SiteHeader.astro";
import MobileNav from "../components/layout/MobileNav.astro";
import LayoutBreadcrumb from "../components/layout/LayoutBreadcrumb.astro";
import CtaSectionIntro from "../components/sections/CtaSectionIntro.astro";
import CtaSectionContact from "../components/sections/CtaSectionContact.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import FixedFooter from "../components/layout/FixedFooter.astro";
import ContactModal from "../components/layout/ContactModal.astro";

interface Props {
  title?: string;
  /** 指定時のみパンくずを表示（トップページでは未指定） */
  breadcrumb?: string;
  /** CTAイントロ（吹き出しエリア）を表示する */
  showCtaSectionIntro?: boolean;
  /** CTA問い合わせブロックを表示する */
  showCtaSectionContact?: boolean;
}

const {
  title = "集客のチカラ",
  breadcrumb,
  showCtaSectionIntro = true,
  showCtaSectionContact = true,
} = Astro.props;

const showCtaSection = showCtaSectionIntro || showCtaSectionContact;
const ctaSectionLabelledBy =
  showCtaSectionIntro ? "cta-heading" : "cta-contact-heading";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body x-data class="layout min-h-screen bg-white font-sans text-(--base-text) antialiased">
    <SiteHeader />
    <MobileNav />

    {breadcrumb && <LayoutBreadcrumb items={[{ label: "ホーム", href: "/" }, { label: breadcrumb }]} />}

    <main class="layout__main min-h-[1000px]">
      <slot />
    </main>

    {
      showCtaSection && (
        <section class="cta-section flex flex-col overflow-hidden" aria-labelledby={ctaSectionLabelledBy}>
          {showCtaSectionIntro && <CtaSectionIntro />}
          {showCtaSectionContact && <CtaSectionContact triangleColor="#e0f2ff" />}
        </section>
      )
    }
    <SiteFooter />
    <FixedFooter />
    <ContactModal />
  </body>
</html>
