---
import "../styles/global.css";
import SiteHeader from "../components/layout/SiteHeader.astro";
import MobileNav from "../components/layout/MobileNav.astro";
import LayoutBreadcrumb from "../components/layout/LayoutBreadcrumb.astro";
import CtaSection from "../components/sections/CtaSection.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import ContactModal from "../components/layout/ContactModal.astro";

interface Props {
  title?: string;
  /** 指定時のみパンくずを表示（トップページでは未指定） */
  breadcrumb?: string;
}

const { title = "集客のチカラ", breadcrumb } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body x-data class="layout min-h-screen bg-white font-sans text-(--base-text) antialiased">
    <SiteHeader />
    <MobileNav />

    {breadcrumb && <LayoutBreadcrumb items={[{ label: "HOME", href: "/" }, { label: breadcrumb }]} />}

    <main class="layout__main min-h-[1000px]">
      <slot />
    </main>

    <CtaSection />
    <SiteFooter />
    <ContactModal />
  </body>
</html>
